---
/**
 * BaseLayout.astro
 * Propósito: Layout base con SEO completo, schema JSON-LD y OG tags.
 * Principio Information Expert: recibe title/description opcionales —
 * los defaults vienen de SITE (fuente única de verdad).
 * Relación: envuelve todas las páginas. Consume FAQ_ITEMS para FAQPage schema.
 */

import { SITE } from '../content/site';
import { FAQ_ITEMS } from '../content/faq';
import Header from '../components/layout/Header.astro';
import Footer from '../components/layout/Footer.astro';
import Analytics from '@vercel/analytics/astro';
import SpeedInsights from '@vercel/speed-insights/astro';
import '../styles/global.css';
import '../styles/animations.css';

export interface BaseLayoutProps {
  title?: string;
  description?: string;
  image?: string;
  canonicalUrl?: string;
  noIndex?: boolean;
}

const {
  title = `${SITE.tagline} | ${SITE.name}`,
  description = SITE.description,
  image = `${SITE.url}/images/og-image.jpg`,
  canonicalUrl = SITE.url,
  noIndex = false,
} = Astro.props as BaseLayoutProps;

// ── Schema JSON-LD ─────────────────────────────────────────────────────────

const schemaProfessionalService = {
  '@context': 'https://schema.org',
  '@type': 'ProfessionalService',
  '@id': `${SITE.url}/#business`,
  name: SITE.name,
  description: SITE.description,
  url: SITE.url,
  telephone: SITE.phone,
  email: SITE.email,
  founder: {
    '@type': 'Person',
    '@id': `${SITE.url}/#founder`,
    name: SITE.founder.name,
    jobTitle: SITE.founder.role,
    url: SITE.url,
    sameAs: [SITE.social.instagram].filter(Boolean),
  },
  address: {
    '@type': 'PostalAddress',
    addressLocality: SITE.location.city,
    addressRegion: SITE.location.region,
    addressCountry: SITE.location.country,
  },
  areaServed: [
    { '@type': 'City', name: 'La Serena' },
    { '@type': 'City', name: 'Coquimbo' },
  ],
  serviceType: [
    'Diseño Web',
    'Páginas Web Profesionales',
    'Desarrollo Web',
    'SEO Local',
    'Posicionamiento en Google',
    'Google My Business',
    'Marketing Digital',
    'Marketing Online',
    'Optimización Web',
  ],
  priceRange: '$$$',
  inLanguage: 'es-CL',
};

const schemaFAQPage = {
  '@context': 'https://schema.org',
  '@type': 'FAQPage',
  mainEntity: FAQ_ITEMS.map((item) => ({
    '@type': 'Question',
    name: item.question,
    acceptedAnswer: {
      '@type': 'Answer',
      text: item.answer,
    },
  })),
};

const schemaBreadcrumb = {
  '@context': 'https://schema.org',
  '@type': 'BreadcrumbList',
  itemListElement: [
    {
      '@type': 'ListItem',
      position: 1,
      name: 'Inicio',
      item: SITE.url,
    },
  ],
};
---

<!doctype html>
<html lang="es-CL">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />

    <!-- SEO primario -->
    <title>{title}</title>
    <meta name="description" content={description} />
    <link rel="canonical" href={canonicalUrl} />
    {noIndex && <meta name="robots" content="noindex, nofollow" />}

    <!-- Open Graph -->
    <meta property="og:type" content="website" />
    <meta property="og:url" content={canonicalUrl} />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:image" content={image} />
    <meta property="og:image:width" content="1200" />
    <meta property="og:image:height" content="630" />
    <meta property="og:image:alt" content={`${SITE.name} — ${SITE.tagline}`} />
    <meta property="og:site_name" content={SITE.name} />
    <meta property="og:locale" content="es_CL" />

    <!-- Twitter Card -->
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={image} />

    <!-- Local SEO -->
    <meta name="geo.region" content="CL-CO" />
    <meta name="geo.placename" content={`${SITE.location.city}, Chile`} />

    <!-- Favicon -->
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />

    <!-- Preconnect Google Fonts -->
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />

    <!-- Google Fonts: Lato -->
    <link
      href="https://fonts.googleapis.com/css2?family=Lato:wght@300;400;700;900&display=swap"
      rel="stylesheet"
    />

    <!-- Schema JSON-LD -->
    <script type="application/ld+json" set:html={JSON.stringify(schemaProfessionalService)} />
    <script type="application/ld+json" set:html={JSON.stringify(schemaFAQPage)} />
    <script type="application/ld+json" set:html={JSON.stringify(schemaBreadcrumb)} />

    <!-- Slot para schemas adicionales por página (ej: Article en posts de blog) -->
    <slot name="head" />

    <!-- Theme color mobile -->
    <meta name="theme-color" content="#F0F8FC" />

    <!-- Google Analytics 4 -->
    <script async src="https://www.googletagmanager.com/gtag/js?id=G-7LH63DBJDK"></script>
    <script>
      window.dataLayer = window.dataLayer || [];
      function gtag(){dataLayer.push(arguments);}
      gtag('js', new Date());
      gtag('config', 'G-7LH63DBJDK');
    </script>
  </head>

  <body>
    <!-- Efecto de fondo — orbs animados, position fixed -->
    <div class="bg-mesh" aria-hidden="true">
      <div class="bg-mesh__orb bg-mesh__orb--1"></div>
      <div class="bg-mesh__orb bg-mesh__orb--2"></div>
      <div class="bg-mesh__orb bg-mesh__orb--3"></div>
    </div>
    <!-- Grid de puntos animado -->
    <div class="bg-dots" aria-hidden="true"></div>
    <!-- Línea de scan suave -->
    <div class="bg-scan" aria-hidden="true"></div>

    <Header />
    <main id="main-content" tabindex="-1">
      <slot />
    </main>
    <Footer />

    <!-- Botón flotante WhatsApp -->
    <a
      href={`https://wa.me/${SITE.whatsapp}?text=${encodeURIComponent('hola Gautama Digital vi tu página web y quisiera conversar contigo')}`}
      class="whatsapp-float"
      target="_blank"
      rel="noopener noreferrer"
      aria-label="Contactar por WhatsApp"
    >
      <svg aria-hidden="true" width="28" height="28" viewBox="0 0 24 24" fill="currentColor">
        <path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413z"/>
      </svg>
    </a>

    <style>
      .whatsapp-float {
        position: fixed;
        bottom: 28px;
        left: 28px;
        z-index: 9999;
        width: 56px;
        height: 56px;
        background-color: #25D366;
        color: #ffffff;
        border-radius: 50%;
        display: flex;
        align-items: center;
        justify-content: center;
        box-shadow: 0 4px 20px rgba(37, 211, 102, 0.45);
        text-decoration: none;
        animation: wa-bounce 2.4s ease-in-out infinite;
        transition: box-shadow 0.2s ease, background-color 0.2s ease;
      }

      .whatsapp-float:hover {
        background-color: #20BD5C;
        box-shadow: 0 6px 28px rgba(37, 211, 102, 0.6);
        animation-play-state: paused;
        transform: scale(1.1);
      }

      @keyframes wa-bounce {
        0%, 100% { transform: scale(1); }
        30%       { transform: scale(1.12); }
        50%       { transform: scale(0.96); }
        70%       { transform: scale(1.06); }
      }
    </style>

    <!-- Scroll reveal global — se activa una vez que el DOM está listo -->
    <script>
      import { initScrollReveal, initWordReveal } from '../utils/animations';
      // Pequeño delay para no competir con la animación del hero
      setTimeout(() => {
        initScrollReveal();
        initWordReveal();
      }, 300);
    </script>

    <!-- Vercel Analytics -->
    <Analytics />

    <!-- Vercel Speed Insights -->
    <SpeedInsights />
  </body>
</html>
