---
/**
 * Process.astro
 * Propósito: Muestra el proceso de trabajo en 3 pasos.
 * Objetivo: reducir ansiedad del prospecto — saben exactamente qué pasa.
 * Relación: consume PROCESS_STEPS.
 */

import SectionLabel from '../ui/SectionLabel.astro';
import { PROCESS_STEPS } from '../../content/process';
---

<section class="process section" id="proceso" aria-labelledby="process-heading">
  <div class="container">
    <div class="process__header gs-fade-up">
      <SectionLabel text="CÓMO TRABAJAMOS" align="center" />
      <h2 class="process__title" id="process-heading">
        Simple, transparente<br />
        <span class="text-gradient-gold">y sin sorpresas.</span>
      </h2>
      <p class="process__sub">
        De la primera llamada al sitio en vivo — en 10 a 15 días hábiles.
      </p>
    </div>

    <div class="process__steps" data-stagger-container>
      {PROCESS_STEPS.map((step, i) => (
        <div class="process__step gs-fade-up">
          <!-- Número -->
          <div class="process__step-number" aria-hidden="true">{step.number}</div>

          <!-- Línea conectora (no en el último) -->
          {i < PROCESS_STEPS.length - 1 && (
            <div class="process__connector" aria-hidden="true"></div>
          )}

          <!-- Contenido -->
          <div class="process__step-content">
            <h3 class="process__step-title">{step.title}</h3>
            <p class="process__step-desc">{step.description}</p>
            <span class="process__step-detail">{step.detail}</span>
          </div>
        </div>
      ))}
    </div>
  </div>
</section>

<style>
  /* Header */
  .process__header {
    text-align: center;
    margin-bottom: var(--space-12);
  }

  .process__title {
    font-size: clamp(var(--text-3xl), 4vw, var(--text-5xl));
    margin-bottom: var(--space-4);
  }

  .process__sub {
    font-size: var(--text-base);
    color: var(--color-text-secondary);
    max-width: 480px;
    margin-inline: auto;
    line-height: var(--leading-relaxed);
  }

  /* Steps layout */
  .process__steps {
    display: flex;
    flex-direction: column;
    gap: var(--space-8);
    position: relative;
    max-width: 720px;
    margin-inline: auto;
  }

  .process__step {
    display: grid;
    grid-template-columns: 64px 1fr;
    grid-template-rows: auto auto;
    gap: 0 var(--space-6);
    position: relative;
  }

  /* Número */
  .process__step-number {
    grid-row: 1 / 3;
    width: 64px;
    height: 64px;
    display: flex;
    align-items: center;
    justify-content: center;
    font-family: var(--font-headline);
    font-size: var(--text-xl);
    font-weight: var(--weight-extrabold);
    color: var(--color-gold);
    background: rgba(201, 168, 76, 0.08);
    border: 1px solid var(--color-border);
    border-radius: var(--radius-lg);
    flex-shrink: 0;
    transition: border-color var(--transition-base), background-color var(--transition-base);
    z-index: 1;
  }

  .process__step:hover .process__step-number {
    border-color: var(--color-gold);
    background: rgba(201, 168, 76, 0.15);
  }

  /* Línea conectora vertical */
  .process__connector {
    position: absolute;
    left: 32px;
    top: 64px;
    width: 1px;
    height: calc(100% + var(--space-8));
    background: linear-gradient(to bottom, var(--color-border), transparent);
  }

  /* Contenido del paso */
  .process__step-content {
    display: flex;
    flex-direction: column;
    gap: var(--space-2);
    padding-top: var(--space-2);
  }

  .process__step-title {
    font-family: var(--font-headline);
    font-size: var(--text-xl);
    font-weight: var(--weight-bold);
    color: var(--color-text-primary);
    line-height: var(--leading-snug);
  }

  .process__step-desc {
    font-size: var(--text-sm);
    color: var(--color-text-secondary);
    line-height: var(--leading-relaxed);
  }

  .process__step-detail {
    display: inline-block;
    font-family: var(--font-subhead);
    font-size: var(--text-xs);
    font-weight: var(--weight-semibold);
    color: var(--color-gold);
    letter-spacing: var(--tracking-wide);
    text-transform: uppercase;
    margin-top: var(--space-1);
  }

  /* Responsive — horizontal en desktop */
  @media (min-width: 900px) {
    .process__steps {
      flex-direction: row;
      align-items: flex-start;
      max-width: 100%;
      gap: 0;
    }

    .process__step {
      flex: 1;
      display: flex;
      flex-direction: column;
      align-items: center;
      text-align: center;
      padding-inline: var(--space-4);
      grid-template-columns: unset;
      grid-template-rows: unset;
    }

    .process__step-number {
      grid-row: unset;
      margin-bottom: var(--space-4);
    }

    .process__connector {
      /* En desktop, la línea es horizontal */
      left: auto;
      right: calc(-50% + 32px);
      top: 32px;
      width: calc(100% - 64px);
      height: 1px;
      background: linear-gradient(to right, var(--color-border), transparent);
    }

    .process__step-content {
      align-items: center;
      padding-top: 0;
    }
  }
</style>
