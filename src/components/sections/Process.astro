---
/**
 * Process.astro
 * Propósito: Muestra el proceso de trabajo en 3 pasos.
 * Objetivo: reducir ansiedad del prospecto — saben exactamente qué pasa.
 * Relación: consume PROCESS_STEPS.
 */

import SectionLabel from '../ui/SectionLabel.astro';
import { PROCESS_STEPS } from '../../content/process';

/* Íconos SVG inline por paso */
const stepIcons = [
  /* 01 — Diagnóstico: lupa + cerebro */
  `<circle cx="11" cy="11" r="8"/><line x1="21" y1="21" x2="16.65" y2="16.65"/>`,
  /* 02 — Construcción: código */
  `<polyline points="16 18 22 12 16 6"/><polyline points="8 6 2 12 8 18"/>`,
  /* 03 — Lanzamiento: cohete */
  `<path d="M4.5 16.5c-1.5 1.5-1.5 3 0 3s3-1.5 3-3-1.5-3-3-3"/><path d="M12 2s-5 4-5 10a5 5 0 0010 0c0-6-5-10-5-10z"/><circle cx="12" cy="12" r="1"/>`,
];
---

<section class="process section" id="proceso" aria-labelledby="process-heading">
  <div class="container">

    <div class="process__header" data-scroll-children>
      <SectionLabel text="CÓMO TRABAJAMOS" align="center" />
      <h2 class="process__title" id="process-heading">
        Tu página web en Google<br />
        <span class="text-gradient-gold">en 3 pasos simples.</span>
      </h2>
      <p class="process__sub">
        Del diagnóstico gratuito a tu sitio publicado y posicionado — en 10 a 15 días hábiles.
        Sin tecnicismos, sin sorpresas, sin mensualidades.
      </p>
    </div>

    <div class="process__steps">
      {PROCESS_STEPS.map((step, i) => (
        <div class="process__step gs-fade-up" style={`animation-delay: ${i * 100}ms`}>

          <!-- Número flotante de fondo -->
          <div class="process__bg-number" aria-hidden="true">{step.number}</div>

          <!-- Ícono + badge de paso -->
          <div class="process__icon-wrap">
            <svg
              width="26"
              height="26"
              viewBox="0 0 24 24"
              fill="none"
              stroke="currentColor"
              stroke-width="1.8"
              stroke-linecap="round"
              stroke-linejoin="round"
              aria-hidden="true"
              set:html={stepIcons[i]}
            />
          </div>

          <!-- Línea conectora (entre pasos en desktop) -->
          {i < PROCESS_STEPS.length - 1 && (
            <div class="process__connector" aria-hidden="true">
              <div class="process__connector-line"></div>
              <svg class="process__connector-arrow" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true">
                <path d="M5 12h14M12 5l7 7-7 7"/>
              </svg>
            </div>
          )}

          <div class="process__step-content">
            <span class="process__step-num">{step.number}</span>
            <h3 class="process__step-title">{step.title}</h3>
            <p class="process__step-desc">{step.description}</p>
            <span class="process__step-detail">
              <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true">
                <circle cx="12" cy="12" r="10"/><polyline points="12 6 12 12 16 14"/>
              </svg>
              {step.detail}
            </span>
          </div>

        </div>
      ))}
    </div>

    <!-- Garantía visual -->
    <div class="process__guarantee gs-fade-up">
      <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true">
        <path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"/>
        <polyline points="9 12 11 14 15 10"/>
      </svg>
      <span>Sin contrato de permanencia · Sin mensualidades · Sin sorpresas</span>
    </div>

  </div>
</section>

<script>
  import { initScrollReveal } from '../../utils/animations';
  initScrollReveal();
</script>

<style>
  .process {
    background-color: var(--color-bg);
  }

  /* Header */
  .process__header {
    text-align: center;
    margin-bottom: var(--space-16);
  }

  .process__title {
    font-size: clamp(var(--text-3xl), 4vw, var(--text-5xl));
    margin-bottom: var(--space-4);
  }

  .process__sub {
    font-size: var(--text-base);
    color: var(--color-text-secondary);
    max-width: 480px;
    margin-inline: auto;
    line-height: var(--leading-relaxed);
  }

  /* Steps layout */
  .process__steps {
    display: flex;
    flex-direction: column;
    gap: var(--space-6);
    position: relative;
    margin-bottom: var(--space-12);
  }

  /* Paso individual */
  .process__step {
    position: relative;
    background-color: var(--color-bg-surface);
    border: 1px solid var(--color-border);
    border-radius: var(--radius-2xl);
    padding: var(--space-8) var(--space-8) var(--space-8) var(--space-8);
    overflow: hidden;
    display: flex;
    flex-direction: column;
    gap: var(--space-4);
    transition: border-color var(--transition-base), box-shadow var(--transition-slow), transform var(--transition-slow);
  }

  .process__step:hover {
    border-color: var(--color-border-hover);
    box-shadow: var(--shadow-card);
    transform: translateY(-2px);
  }

  /* Número gigante de fondo */
  .process__bg-number {
    position: absolute;
    right: var(--space-6);
    top: 50%;
    transform: translateY(-50%);
    font-family: var(--font-headline);
    font-size: 7rem;
    font-weight: var(--weight-extrabold);
    color: var(--color-gold);
    opacity: 0.05;
    line-height: 1;
    user-select: none;
    pointer-events: none;
    letter-spacing: -0.05em;
  }

  /* Ícono */
  .process__icon-wrap {
    width: 52px;
    height: 52px;
    display: flex;
    align-items: center;
    justify-content: center;
    background: linear-gradient(135deg, rgba(4, 119, 191, 0.12), rgba(4, 196, 217, 0.08));
    border: 1px solid var(--color-border);
    border-radius: var(--radius-xl);
    color: var(--color-gold);
    flex-shrink: 0;
    transition: background var(--transition-base), border-color var(--transition-base), color var(--transition-base);
  }

  .process__step:hover .process__icon-wrap {
    background: linear-gradient(135deg, rgba(4, 119, 191, 0.20), rgba(4, 196, 217, 0.14));
    border-color: var(--color-gold);
    color: var(--color-gold-light);
  }

  /* Conector (mobile: vertical) */
  .process__connector {
    display: none;
  }

  /* Contenido */
  .process__step-content {
    display: flex;
    flex-direction: column;
    gap: var(--space-2);
    position: relative;
  }

  .process__step-num {
    font-family: var(--font-subhead);
    font-size: var(--text-xs);
    font-weight: var(--weight-bold);
    letter-spacing: var(--tracking-widest);
    color: var(--color-gold);
    text-transform: uppercase;
  }

  .process__step-title {
    font-family: var(--font-headline);
    font-size: clamp(var(--text-xl), 2vw, var(--text-2xl));
    font-weight: var(--weight-bold);
    color: var(--color-text-primary);
    line-height: var(--leading-snug);
  }

  .process__step-desc {
    font-size: var(--text-sm);
    color: var(--color-text-secondary);
    line-height: var(--leading-relaxed);
    max-width: 480px;
  }

  .process__step-detail {
    display: inline-flex;
    align-items: center;
    gap: var(--space-2);
    font-family: var(--font-subhead);
    font-size: var(--text-xs);
    font-weight: var(--weight-semibold);
    color: var(--color-text-muted);
    letter-spacing: var(--tracking-wide);
    margin-top: var(--space-1);
  }

  /* Garantía */
  .process__guarantee {
    display: flex;
    align-items: center;
    justify-content: center;
    gap: var(--space-3);
    padding: var(--space-4) var(--space-6);
    background: color-mix(in srgb, var(--color-gold) 6%, var(--color-bg-surface));
    border: 1px solid var(--color-border);
    border-radius: var(--radius-full);
    font-family: var(--font-subhead);
    font-size: var(--text-sm);
    font-weight: var(--weight-semibold);
    color: var(--color-text-secondary);
    max-width: 480px;
    margin-inline: auto;
  }

  .process__guarantee svg {
    color: var(--color-gold);
    flex-shrink: 0;
  }

  /* ── Desktop: horizontal ── */
  @media (min-width: 900px) {
    .process__steps {
      flex-direction: row;
      align-items: stretch;
      gap: 0;
    }

    .process__step {
      flex: 1;
      border-radius: 0;
      border-right: none;
    }

    .process__step:first-child {
      border-radius: var(--radius-2xl) 0 0 var(--radius-2xl);
    }

    .process__step:last-child {
      border-radius: 0 var(--radius-2xl) var(--radius-2xl) 0;
      border-right: 1px solid var(--color-border);
    }

    .process__step:hover {
      transform: translateY(-4px);
      z-index: 1;
      border-color: var(--color-gold);
      border-right: 1px solid var(--color-gold);
    }

    .process__step:hover + .process__step {
      border-left-color: var(--color-gold);
    }

    .process__connector {
      display: none;
    }

    .process__step-desc {
      max-width: 100%;
    }

    .process__bg-number {
      font-size: 9rem;
      opacity: 0.04;
    }
  }
</style>
