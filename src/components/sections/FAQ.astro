---
/**
 * FAQ.astro
 * Accordion con las 7 preguntas frecuentes — cierra objeciones antes de comprar.
 */

import SectionLabel from '../ui/SectionLabel.astro';
import { FAQ_ITEMS } from '../../content/faq';
import { SITE } from '../../content/site';
---

<section class="faq section" id="faq" aria-labelledby="faq-heading">
  <div class="container">

    <div class="faq__top" data-scroll-children>
      <SectionLabel text="PREGUNTAS FRECUENTES" align="center" />
      <h2 class="faq__title" id="faq-heading">
        Lo que todos preguntan<br />
        <span class="text-gradient-gold">antes de empezar.</span>
      </h2>
    </div>

    <div class="faq__accordion" role="list">
      {FAQ_ITEMS.map((item, i) => (
        <details class="faq-item gs-fade-up" style={`animation-delay: ${i * 55}ms`}>
          <summary class="faq-item__header" role="listitem">
            <span class="faq-item__num">0{i + 1}</span>
            <span class="faq-item__q">{item.question}</span>
            <span class="faq-item__chevron" aria-hidden="true">
              <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round">
                <polyline points="6 9 12 15 18 9"/>
              </svg>
            </span>
          </summary>
          <div class="faq-item__body">
            <p class="faq-item__a">{item.answer}</p>
          </div>
        </details>
      ))}
    </div>

    <div class="faq__footer gs-fade-up">
      <p>
        ¿Otra consulta?
        <a
          href={`https://wa.me/${SITE.whatsapp}?text=${encodeURIComponent('Hola Seba, tengo una consulta sobre tu servicio de diseño web.')}`}
          class="link-gold"
          target="_blank"
          rel="noopener noreferrer"
        >
          Escríbeme por WhatsApp
        </a>
        — respondo el mismo día.
      </p>
    </div>

  </div>
</section>

<script>
  import { initScrollReveal } from '../../utils/animations';
  initScrollReveal();
</script>

<style>
  .faq {
    background-color: var(--color-bg-surface);
  }

  .faq__top {
    text-align: center;
    margin-bottom: var(--space-12);
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: var(--space-4);
  }

  .faq__title {
    font-size: clamp(var(--text-3xl), 4vw, var(--text-5xl));
    font-weight: var(--weight-extrabold);
    line-height: var(--leading-tight);
  }

  /* Accordion */
  .faq__accordion {
    max-width: 760px;
    margin-inline: auto;
    display: flex;
    flex-direction: column;
    gap: 0;
    border: 1px solid var(--color-border);
    border-radius: var(--radius-xl);
    overflow: hidden;
    margin-bottom: var(--space-10);
  }

  .faq-item {
    background: var(--color-bg);
    border-bottom: 1px solid var(--color-border);
  }

  .faq-item:last-child {
    border-bottom: none;
  }

  .faq-item__header {
    display: flex;
    align-items: center;
    gap: var(--space-4);
    padding: var(--space-5) var(--space-6);
    cursor: pointer;
    list-style: none;
    user-select: none;
    transition: background var(--transition-fast);
  }

  .faq-item__header::-webkit-details-marker { display: none; }

  .faq-item:hover .faq-item__header,
  .faq-item[open] .faq-item__header {
    background: var(--color-bg-overlay);
  }

  .faq-item__num {
    font-family: var(--font-subhead);
    font-size: var(--text-xs);
    font-weight: var(--weight-extrabold);
    color: var(--color-gold);
    letter-spacing: var(--tracking-widest);
    opacity: 0.55;
    flex-shrink: 0;
    min-width: 28px;
  }

  .faq-item__q {
    flex: 1;
    font-family: var(--font-headline);
    font-size: var(--text-base);
    font-weight: var(--weight-semibold);
    color: var(--color-text-primary);
    line-height: var(--leading-snug);
  }

  .faq-item__chevron {
    flex-shrink: 0;
    color: var(--color-text-muted);
    transition: transform var(--transition-base);
    display: flex;
    align-items: center;
  }

  .faq-item[open] .faq-item__chevron {
    transform: rotate(180deg);
  }

  .faq-item__body {
    padding: 0 var(--space-6) var(--space-5) calc(28px + var(--space-4) + var(--space-6));
  }

  .faq-item__a {
    font-size: var(--text-sm);
    color: var(--color-text-secondary);
    line-height: var(--leading-relaxed);
  }

  /* Footer link */
  .faq__footer {
    text-align: center;
    font-size: var(--text-base);
    color: var(--color-text-secondary);
    line-height: var(--leading-relaxed);
  }
</style>
