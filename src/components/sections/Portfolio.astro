---
/**
 * Portfolio.astro
 * Propósito: Muestra los proyectos reales entregados por Gautama Digital.
 * Diseño: tarjetas con mockup de browser + acento de color por cliente.
 * Relación: consume PORTFOLIO de content/portfolio.ts.
 */

import SectionLabel from '../ui/SectionLabel.astro';
import { PORTFOLIO } from '../../content/portfolio';
---

<section class="portfolio section" id="portafolio" aria-labelledby="portfolio-heading">
  <div class="container">

    <div class="portfolio__header" data-scroll-children>
      <SectionLabel text="PORTAFOLIO" align="center" />
      <h2 class="portfolio__title gs-fade-up" id="portfolio-heading">
        Sitios que ya están
        <span class="text-gradient-gold">generando resultados.</span>
      </h2>
      <p class="portfolio__sub">
        Cada proyecto es diseñado desde cero. Sin plantillas compradas. Sin componentes genéricos.
      </p>
    </div>

    <div class="portfolio__grid">
      {PORTFOLIO.map((project, i) => (
        <article
          class="portfolio__card gs-fade-up"
          style={`animation-delay: ${i * 60}ms`}
          aria-label={project.name}
        >
          <!-- Mockup visual -->
          <div class="portfolio__mockup" style={`--accent: ${project.accentColor}`} data-has-url={project.href ? 'true' : undefined}>
            {project.href && (
              <div class="portfolio__live" aria-hidden="true">
                <span class="portfolio__live-dot"></span>
                LIVE
              </div>
            )}
            <div class="portfolio__browser-bar">
              <span class="portfolio__dot"></span>
              <span class="portfolio__dot"></span>
              <span class="portfolio__dot"></span>
              <span class="portfolio__url-bar">
                {project.url ?? project.name.toLowerCase().replace(/\s/g, '') + '.cl'}
              </span>
            </div>
            <div class="portfolio__preview">
              {project.href ? (
                <div class="portfolio__screenshot-wrap">
                  <img
                    src={`https://api.microlink.io/?url=${encodeURIComponent(project.href)}&screenshot=true&meta=false&embed=screenshot.url`}
                    alt={`Vista previa de ${project.name}`}
                    class="portfolio__screenshot"
                    loading="lazy"
                    decoding="async"
                    width="600"
                    height="400"
                    onerror="this.style.display='none';this.nextElementSibling.style.display='flex'"
                  />
                  <div class="portfolio__preview-lines portfolio__preview-lines--fallback" style="display:none">
                    <span class="portfolio__line portfolio__line--title" style={`background: ${project.accentColor}`}></span>
                    <span class="portfolio__line portfolio__line--sub"></span>
                    <span class="portfolio__line portfolio__line--sub portfolio__line--short"></span>
                    <div class="portfolio__preview-blocks">
                      <span class="portfolio__block" style={`background: ${project.accentColor}22`}></span>
                      <span class="portfolio__block" style={`background: ${project.accentColor}22`}></span>
                      <span class="portfolio__block" style={`background: ${project.accentColor}22`}></span>
                    </div>
                  </div>
                </div>
              ) : (
                /* Mockup de website con los colores del cliente */
                <div class="site-mock" style={`--c: ${project.accentColor}`} aria-hidden="true">
                  {/* Nav */}
                  <div class="site-mock__nav">
                    <span class="site-mock__logo"></span>
                    <div class="site-mock__nav-links">
                      <span></span><span></span><span></span>
                    </div>
                  </div>
                  {/* Hero */}
                  <div class="site-mock__hero">
                    <span class="site-mock__hero-h1"></span>
                    <span class="site-mock__hero-sub"></span>
                    <span class="site-mock__hero-btn"></span>
                  </div>
                  {/* Cards */}
                  <div class="site-mock__cards">
                    <span class="site-mock__card"></span>
                    <span class="site-mock__card"></span>
                    <span class="site-mock__card"></span>
                  </div>
                </div>
              )}
            </div>
          </div>

          <!-- Info -->
          <div class="portfolio__info">
            <div class="portfolio__meta">
              <h3 class="portfolio__name">{project.name}</h3>
              <span class="portfolio__industry">{project.industry}</span>
            </div>

            <p class="portfolio__description">{project.description}</p>

            <div class="portfolio__footer">
              <div class="portfolio__tags" aria-label="Servicios aplicados">
                {project.tags.map((tag) => (
                  <span class="portfolio__tag">{tag}</span>
                ))}
              </div>

              {project.href ? (
                <a
                  href={project.href}
                  class="portfolio__link"
                  target="_blank"
                  rel="noopener noreferrer"
                  aria-label={`Ver sitio de ${project.name}`}
                >
                  Ver sitio
                  <svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true">
                    <path d="M7 17L17 7M17 7H7M17 7v10"/>
                  </svg>
                </a>
              ) : (
                <span class="portfolio__delivered">
                  <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" aria-hidden="true">
                    <path d="M22 11.08V12a10 10 0 11-5.93-9.14"/><polyline points="22 4 12 14.01 9 11.01"/>
                  </svg>
                  Entregado
                </span>
              )}
            </div>
          </div>
        </article>
      ))}
    </div>

  </div>
</section>

<script>
  import { initScrollReveal } from '../../utils/animations';
  initScrollReveal();
</script>

<style>
  .portfolio {
    background-color: var(--color-bg);
  }

  .portfolio__header {
    text-align: center;
    margin-bottom: var(--space-12);
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: var(--space-4);
  }

  .portfolio__title {
    font-size: clamp(var(--text-3xl), 4vw, var(--text-5xl));
    font-weight: var(--weight-extrabold);
    line-height: var(--leading-tight);
  }

  .portfolio__sub {
    font-size: var(--text-base);
    color: var(--color-text-secondary);
    max-width: 440px;
    line-height: var(--leading-relaxed);
  }

  /* Grid */
  .portfolio__grid {
    display: grid;
    grid-template-columns: 1fr;
    gap: var(--space-6);
  }

  @media (min-width: 640px) {
    .portfolio__grid {
      grid-template-columns: repeat(2, 1fr);
    }
  }

  @media (min-width: 1024px) {
    .portfolio__grid {
      grid-template-columns: repeat(3, 1fr);
    }
  }

  /* Card */
  .portfolio__card {
    background-color: var(--color-bg-surface);
    border: 1px solid var(--color-border);
    border-radius: var(--radius-xl);
    overflow: hidden;
    display: flex;
    flex-direction: column;
    transition: transform var(--transition-slow), border-color var(--transition-base), box-shadow var(--transition-slow);
  }

  .portfolio__card:hover {
    transform: translateY(-4px);
    border-color: var(--color-border-hover);
    box-shadow: var(--shadow-card);
  }

  /* Browser mockup */
  .portfolio__mockup {
    position: relative;
    background: #0d0d1a;
    padding: var(--space-3);
    border-bottom: 1px solid var(--color-border);
  }

  /* LIVE badge — solo en proyectos con URL real */
  .portfolio__live {
    position: absolute;
    top: var(--space-2);
    right: var(--space-2);
    z-index: 2;
    display: inline-flex;
    align-items: center;
    gap: 4px;
    font-size: 9px;
    font-weight: 700;
    letter-spacing: 0.1em;
    color: #2ECC71;
    background: rgba(46, 204, 113, 0.12);
    border: 1px solid rgba(46, 204, 113, 0.3);
    border-radius: var(--radius-full);
    padding: 2px 7px;
  }

  .portfolio__live-dot {
    width: 5px;
    height: 5px;
    border-radius: 50%;
    background: #2ECC71;
    flex-shrink: 0;
    animation: live-pulse 1.8s ease-in-out infinite;
  }

  @keyframes live-pulse {
    0%, 100% { box-shadow: 0 0 0 0 rgba(46, 204, 113, 0.5); }
    50%       { box-shadow: 0 0 0 5px rgba(46, 204, 113, 0); }
  }

  .portfolio__browser-bar {
    display: flex;
    align-items: center;
    gap: var(--space-2);
    margin-bottom: var(--space-2);
  }

  .portfolio__dot {
    width: 8px;
    height: 8px;
    border-radius: 50%;
    background-color: var(--color-border);
    flex-shrink: 0;
  }

  .portfolio__dot:first-child { background-color: #ff5f57; }
  .portfolio__dot:nth-child(2) { background-color: #ffbd2e; }
  .portfolio__dot:nth-child(3) { background-color: #28ca41; }

  .portfolio__url-bar {
    flex: 1;
    background: rgba(255,255,255,0.05);
    border-radius: var(--radius-full);
    font-size: 10px;
    color: var(--color-text-muted);
    padding: 2px var(--space-3);
    font-family: var(--font-mono, monospace);
    white-space: nowrap;
    overflow: hidden;
    text-overflow: ellipsis;
  }

  .portfolio__preview {
    background: linear-gradient(
      160deg,
      color-mix(in srgb, var(--accent) 12%, #0d0d1a) 0%,
      #0d0d1a 60%
    );
    border-radius: var(--radius-md);
    overflow: hidden;
    min-height: 120px;
  }

  /* Screenshot real del sitio */
  .portfolio__screenshot-wrap {
    position: relative;
    min-height: 120px;
  }

  .portfolio__screenshot {
    width: 100%;
    height: 140px;
    object-fit: cover;
    object-position: top center;
    display: block;
    transition: transform var(--transition-slow);
  }

  .portfolio__card:hover .portfolio__screenshot {
    transform: scale(1.03);
  }

  /* Fallback / private placeholder */
  .portfolio__preview-lines {
    display: flex;
    flex-direction: column;
    gap: var(--space-2);
    padding: var(--space-4);
  }

  .portfolio__preview-lines--fallback {
    position: absolute;
    inset: 0;
    background: linear-gradient(160deg, color-mix(in srgb, var(--accent) 12%, #0d0d1a) 0%, #0d0d1a 60%);
  }

  .portfolio__preview-lines--private {
    min-height: 120px;
    justify-content: center;
  }

  .portfolio__private-badge {
    display: inline-flex;
    align-items: center;
    gap: var(--space-2);
    font-size: 10px;
    color: rgba(255,255,255,0.4);
    background: rgba(255,255,255,0.06);
    border: 1px solid rgba(255,255,255,0.08);
    border-radius: var(--radius-full);
    padding: 3px var(--space-3);
    margin-bottom: var(--space-3);
    align-self: flex-start;
  }

  .portfolio__line {
    display: block;
    height: 8px;
    border-radius: var(--radius-full);
    opacity: 0.7;
  }

  .portfolio__line--title {
    width: 55%;
    height: 12px;
    opacity: 0.85;
  }

  .portfolio__line--sub {
    width: 80%;
    background: rgba(255,255,255,0.12);
  }

  .portfolio__line--short {
    width: 50%;
  }

  .portfolio__preview-blocks {
    display: flex;
    gap: var(--space-2);
    margin-top: var(--space-2);
  }

  .portfolio__block {
    flex: 1;
    height: 36px;
    border-radius: var(--radius-md);
    border: 1px solid rgba(255,255,255,0.06);
  }

  /* Info */
  .portfolio__info {
    padding: var(--space-5);
    display: flex;
    flex-direction: column;
    gap: var(--space-3);
    flex: 1;
  }

  .portfolio__meta {
    display: flex;
    flex-direction: column;
    gap: 2px;
  }

  .portfolio__name {
    font-family: var(--font-headline);
    font-size: var(--text-lg);
    font-weight: var(--weight-bold);
    color: var(--color-text-primary);
  }

  .portfolio__industry {
    font-size: var(--text-xs);
    color: var(--color-text-muted);
    letter-spacing: var(--tracking-wide);
  }

  .portfolio__description {
    font-size: var(--text-sm);
    color: var(--color-text-secondary);
    line-height: var(--leading-relaxed);
    flex: 1;
  }

  /* Footer */
  .portfolio__footer {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: var(--space-3);
    padding-top: var(--space-3);
    border-top: 1px solid var(--color-border);
    margin-top: auto;
  }

  .portfolio__tags {
    display: flex;
    flex-wrap: wrap;
    gap: var(--space-2);
  }

  .portfolio__tag {
    font-family: var(--font-subhead);
    font-size: 10px;
    font-weight: var(--weight-semibold);
    letter-spacing: var(--tracking-wide);
    text-transform: uppercase;
    color: var(--color-text-muted);
    background-color: var(--color-bg-overlay);
    border: 1px solid var(--color-border);
    border-radius: var(--radius-full);
    padding: 2px var(--space-2);
    white-space: nowrap;
  }

  .portfolio__link {
    display: inline-flex;
    align-items: center;
    gap: 4px;
    font-family: var(--font-subhead);
    font-size: var(--text-xs);
    font-weight: var(--weight-semibold);
    color: var(--color-gold);
    text-decoration: none;
    white-space: nowrap;
    letter-spacing: var(--tracking-wide);
    flex-shrink: 0;
    transition: gap var(--transition-base);
  }

  .portfolio__link:hover {
    gap: var(--space-2);
  }

  .portfolio__delivered {
    display: inline-flex;
    align-items: center;
    gap: 4px;
    font-family: var(--font-subhead);
    font-size: var(--text-xs);
    font-weight: var(--weight-semibold);
    color: #2ECC71;
    white-space: nowrap;
    flex-shrink: 0;
    letter-spacing: var(--tracking-wide);
  }

  /* ── Mockup de sitio web para proyectos sin URL pública ── */
  .site-mock {
    display: flex;
    flex-direction: column;
    background: color-mix(in srgb, var(--c) 8%, #f8fafc);
    min-height: 130px;
    overflow: hidden;
  }

  /* Nav */
  .site-mock__nav {
    display: flex;
    align-items: center;
    justify-content: space-between;
    padding: 5px 8px;
    background: var(--c);
  }

  .site-mock__logo {
    display: block;
    width: 40px;
    height: 6px;
    border-radius: 3px;
    background: rgba(255,255,255,0.75);
  }

  .site-mock__nav-links {
    display: flex;
    gap: 5px;
  }

  .site-mock__nav-links span {
    display: block;
    width: 20px;
    height: 4px;
    border-radius: 2px;
    background: rgba(255,255,255,0.4);
  }

  /* Hero */
  .site-mock__hero {
    display: flex;
    flex-direction: column;
    gap: 5px;
    padding: 10px 8px 8px;
    background: color-mix(in srgb, var(--c) 12%, white);
    border-bottom: 1px solid color-mix(in srgb, var(--c) 15%, transparent);
  }

  .site-mock__hero-h1 {
    display: block;
    width: 72%;
    height: 9px;
    border-radius: 4px;
    background: color-mix(in srgb, var(--c) 60%, #1a1a1a);
    opacity: 0.85;
  }

  .site-mock__hero-sub {
    display: block;
    width: 55%;
    height: 5px;
    border-radius: 3px;
    background: color-mix(in srgb, var(--c) 30%, #666);
    opacity: 0.5;
  }

  .site-mock__hero-btn {
    display: block;
    width: 48px;
    height: 14px;
    border-radius: 4px;
    background: var(--c);
    opacity: 0.85;
    margin-top: 3px;
  }

  /* Cards row */
  .site-mock__cards {
    display: flex;
    gap: 5px;
    padding: 8px;
    flex: 1;
  }

  .site-mock__card {
    flex: 1;
    border-radius: 4px;
    background: color-mix(in srgb, var(--c) 10%, white);
    border: 1px solid color-mix(in srgb, var(--c) 18%, transparent);
    min-height: 36px;
  }
</style>
