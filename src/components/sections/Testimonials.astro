---
/**
 * Testimonials.astro
 * Propósito: Sección de reseñas de Google My Business.
 * Muestra tarjetas con estrella, texto, autor y enlace a Google.
 * Los datos vienen de content/testimonials.ts (editable sin tocar el componente).
 */

import { TESTIMONIALS, GMB_REVIEWS_URL } from '../../content/testimonials';
import SectionLabel from '../ui/SectionLabel.astro';

const formatDate = (iso: string) => {
  const d = new Date(iso);
  return d.toLocaleDateString('es-CL', { month: 'long', year: 'numeric' });
};
---

<section class="testimonials section" id="testimonios" aria-label="Testimonios de clientes">
  <div class="container">

    <!-- Header -->
    <div class="testimonials__header" data-scroll-children>
      <SectionLabel>Reseñas reales</SectionLabel>
      <h2 class="testimonials__title">
        Lo que dicen nuestros<br />
        <span class="text-gradient-gold">clientes en Google</span>
      </h2>
      <p class="testimonials__sub">
        Reseñas verificadas en Google My Business. Sin filtros, sin edición.
      </p>
    </div>

    <!-- Cards grid -->
    <div class="testimonials__grid">
      {TESTIMONIALS.map((t, i) => (
        <article
          class="testimonial-card shimmer-border gs-fade-up"
          style={`animation-delay: ${i * 80}ms`}
          aria-label={`Reseña de ${t.name}`}
        >
          <!-- Stars -->
          <div class="testimonial-card__stars" aria-label={`${t.rating} de 5 estrellas`}>
            {Array.from({ length: 5 }).map((_, si) => (
              <span class={`testimonial-card__star ${si < t.rating ? 'testimonial-card__star--filled' : ''}`} aria-hidden="true">
                ★
              </span>
            ))}
          </div>

          <!-- Quote -->
          <blockquote class="testimonial-card__text">
            <p>"{t.text}"</p>
          </blockquote>

          <!-- Footer del card -->
          <footer class="testimonial-card__footer">
            <div class="testimonial-card__author">
              <!-- Avatar inicial -->
              <div class="testimonial-card__avatar" aria-hidden="true">
                {t.initial}
              </div>
              <div class="testimonial-card__info">
                <span class="testimonial-card__name">{t.name}</span>
                {t.business && (
                  <span class="testimonial-card__business">{t.business}</span>
                )}
                <span class="testimonial-card__date">{formatDate(t.date)}</span>
              </div>
            </div>

            <!-- Logo Google -->
            <div class="testimonial-card__google" aria-label="Reseña en Google">
              <svg width="18" height="18" viewBox="0 0 24 24" aria-hidden="true">
                <path fill="#4285F4" d="M22.56 12.25c0-.78-.07-1.53-.2-2.25H12v4.26h5.92c-.26 1.37-1.04 2.53-2.21 3.31v2.77h3.57c2.08-1.92 3.28-4.74 3.28-8.09z"/>
                <path fill="#34A853" d="M12 23c2.97 0 5.46-.98 7.28-2.66l-3.57-2.77c-.98.66-2.23 1.06-3.71 1.06-2.86 0-5.29-1.93-6.16-4.53H2.18v2.84C3.99 20.53 7.7 23 12 23z"/>
                <path fill="#FBBC05" d="M5.84 14.09c-.22-.66-.35-1.36-.35-2.09s.13-1.43.35-2.09V7.07H2.18C1.43 8.55 1 10.22 1 12s.43 3.45 1.18 4.93l2.85-2.22.81-.62z"/>
                <path fill="#EA4335" d="M12 5.38c1.62 0 3.06.56 4.21 1.64l3.15-3.15C17.45 2.09 14.97 1 12 1 7.7 1 3.99 3.47 2.18 7.07l3.66 2.84c.87-2.6 3.3-4.53 6.16-4.53z"/>
              </svg>
            </div>
          </footer>
        </article>
      ))}
    </div>

    <!-- CTA a Google -->
    <div class="testimonials__cta gs-fade-up">
      <a
        href={GMB_REVIEWS_URL}
        class="testimonials__gmb-link"
        target="_blank"
        rel="noopener noreferrer"
        aria-label="Ver todas las reseñas en Google My Business"
      >
        <svg width="20" height="20" viewBox="0 0 24 24" aria-hidden="true">
          <path fill="#4285F4" d="M22.56 12.25c0-.78-.07-1.53-.2-2.25H12v4.26h5.92c-.26 1.37-1.04 2.53-2.21 3.31v2.77h3.57c2.08-1.92 3.28-4.74 3.28-8.09z"/>
          <path fill="#34A853" d="M12 23c2.97 0 5.46-.98 7.28-2.66l-3.57-2.77c-.98.66-2.23 1.06-3.71 1.06-2.86 0-5.29-1.93-6.16-4.53H2.18v2.84C3.99 20.53 7.7 23 12 23z"/>
          <path fill="#FBBC05" d="M5.84 14.09c-.22-.66-.35-1.36-.35-2.09s.13-1.43.35-2.09V7.07H2.18C1.43 8.55 1 10.22 1 12s.43 3.45 1.18 4.93l2.85-2.22.81-.62z"/>
          <path fill="#EA4335" d="M12 5.38c1.62 0 3.06.56 4.21 1.64l3.15-3.15C17.45 2.09 14.97 1 12 1 7.7 1 3.99 3.47 2.18 7.07l3.66 2.84c.87-2.6 3.3-4.53 6.16-4.53z"/>
        </svg>
        Ver todas las reseñas en Google
        <svg class="testimonials__arrow" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true">
          <path d="M7 17L17 7M17 7H7M17 7v10"/>
        </svg>
      </a>
    </div>

  </div>
</section>

<script>
  import { initScrollReveal } from '../../utils/animations';
  initScrollReveal();
</script>

<style>
  .testimonials {
    background-color: var(--color-bg-surface);
  }

  /* Header */
  .testimonials__header {
    text-align: center;
    margin-bottom: var(--space-12);
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: var(--space-4);
  }

  .testimonials__title {
    font-size: clamp(var(--text-3xl), 4vw, var(--text-5xl));
    font-weight: var(--weight-extrabold);
  }

  .testimonials__sub {
    color: var(--color-text-secondary);
    font-size: var(--text-base);
    max-width: 440px;
  }

  /* Grid */
  .testimonials__grid {
    display: grid;
    grid-template-columns: 1fr;
    gap: var(--space-6);
    margin-bottom: var(--space-10);
  }

  @media (min-width: 640px) {
    .testimonials__grid {
      grid-template-columns: repeat(2, 1fr);
    }
  }

  @media (min-width: 1024px) {
    .testimonials__grid {
      grid-template-columns: repeat(3, 1fr);
    }
  }

  /* Card */
  .testimonial-card {
    background-color: var(--color-bg);
    border: 1px solid var(--color-border);
    border-radius: var(--radius-xl);
    padding: var(--space-6);
    display: flex;
    flex-direction: column;
    gap: var(--space-4);
    transition: transform var(--transition-slow), box-shadow var(--transition-slow), border-color var(--transition-base);
  }

  .testimonial-card:hover {
    transform: translateY(-4px);
    box-shadow: var(--shadow-gold-hover);
    border-color: var(--color-border-hover);
  }

  /* Stars */
  .testimonial-card__stars {
    display: flex;
    gap: 2px;
  }

  .testimonial-card__star {
    font-size: var(--text-lg);
    color: var(--color-border);
  }

  .testimonial-card__star--filled {
    color: #FBBC05;
  }

  /* Quote */
  .testimonial-card__text {
    flex: 1;
    font-size: var(--text-sm);
    line-height: var(--leading-relaxed);
    color: var(--color-text-secondary);
    font-style: normal;
  }

  /* Footer */
  .testimonial-card__footer {
    display: flex;
    align-items: center;
    justify-content: space-between;
    padding-top: var(--space-4);
    border-top: 1px solid var(--color-border);
  }

  .testimonial-card__author {
    display: flex;
    align-items: center;
    gap: var(--space-3);
  }

  /* Avatar */
  .testimonial-card__avatar {
    width: 40px;
    height: 40px;
    border-radius: 50%;
    background: linear-gradient(135deg, var(--color-gold), var(--color-gold-light));
    color: var(--color-text-inverse);
    font-family: var(--font-headline);
    font-weight: var(--weight-bold);
    font-size: var(--text-base);
    display: flex;
    align-items: center;
    justify-content: center;
    flex-shrink: 0;
  }

  .testimonial-card__info {
    display: flex;
    flex-direction: column;
    gap: 1px;
  }

  .testimonial-card__name {
    font-family: var(--font-subhead);
    font-size: var(--text-sm);
    font-weight: var(--weight-semibold);
    color: var(--color-text-primary);
  }

  .testimonial-card__business {
    font-size: var(--text-xs);
    color: var(--color-text-secondary);
  }

  .testimonial-card__date {
    font-size: var(--text-xs);
    color: var(--color-text-muted);
  }

  .testimonial-card__google {
    opacity: 0.7;
    flex-shrink: 0;
  }

  /* CTA Google */
  .testimonials__cta {
    display: flex;
    justify-content: center;
  }

  .testimonials__gmb-link {
    display: inline-flex;
    align-items: center;
    gap: var(--space-2);
    font-family: var(--font-subhead);
    font-size: var(--text-sm);
    font-weight: var(--weight-semibold);
    color: var(--color-text-secondary);
    border: 1px solid var(--color-border);
    border-radius: var(--radius-full);
    padding: var(--space-3) var(--space-6);
    background-color: var(--color-bg);
    transition: border-color var(--transition-base), color var(--transition-base), box-shadow var(--transition-base);
    text-decoration: none;
  }

  .testimonials__gmb-link:hover {
    border-color: var(--color-border-hover);
    color: var(--color-text-primary);
    box-shadow: var(--shadow-card);
  }

  .testimonials__arrow {
    transition: transform var(--transition-base);
  }

  .testimonials__gmb-link:hover .testimonials__arrow {
    transform: translate(2px, -2px);
  }
</style>
