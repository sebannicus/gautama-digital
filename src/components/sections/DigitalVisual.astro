---
/**
 * DigitalVisual.astro
 * Propósito: Sección visual que muestra las 3 disciplinas clave: SEO, Analíticas y Diseño Web.
 * Usa imágenes reales de Unsplash + overlay de marca + copy persuasivo.
 */

import SectionLabel from '../ui/SectionLabel.astro';

const features = [
  {
    id: 'seo',
    label: 'Posicionamiento',
    title: 'Primero en Google,\nsin pagar ads.',
    description: 'SEO local para que tus clientes te encuentren justo cuando están buscando lo que ofreces. Orgánico y sostenible.',
    metric: '#1',
    metricLabel: 'Posición en Maps — CheckVital',
    img: 'https://images.unsplash.com/photo-1432888498266-38ffec3eaf0a?w=800&auto=format&fit=crop&q=80',
    imgAlt: 'SEO y posicionamiento en buscadores',
    accentColor: '#0477BF',
    icon: `<svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true"><circle cx="11" cy="11" r="8"/><path d="m21 21-4.35-4.35"/></svg>`,
  },
  {
    id: 'analytics',
    label: 'Analíticas',
    title: 'Datos reales.\nDecisiones mejores.',
    description: 'GA4 configurado desde el primer día. Ves de dónde vienen tus visitas, qué hacen y qué los convierte en clientes.',
    metric: 'GA4',
    metricLabel: 'Analytics configurado',
    img: 'https://images.unsplash.com/photo-1460925895917-afdab827c52f?w=800&auto=format&fit=crop&q=80',
    imgAlt: 'Dashboard de analíticas y métricas digitales',
    accentColor: '#04C4D9',
    icon: `<svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true"><polyline points="22 12 18 12 15 21 9 3 6 12 2 12"/></svg>`,
  },
  {
    id: 'web',
    label: 'Diseño Web',
    title: 'Páginas que\nconvierten visitas.',
    description: 'Cada sitio web construido desde cero con arquitectura sólida, velocidad de carga y un diseño que comunica profesionalismo.',
    metric: '100%',
    metricLabel: 'A medida, sin plantillas',
    img: 'https://images.unsplash.com/photo-1547658719-da2b51169166?w=800&auto=format&fit=crop&q=80',
    imgAlt: 'Diseño web profesional y desarrollo de páginas',
    accentColor: '#003F87',
    icon: `<svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true"><rect x="3" y="3" width="18" height="18" rx="2"/><path d="M3 9h18M9 21V9"/></svg>`,
  },
];
---

<section class="dv section" id="disciplinas" aria-labelledby="dv-heading">
  <div class="container">

    <div class="dv__header" data-scroll-children>
      <SectionLabel text="LO QUE HACEMOS" align="center" />
      <h2 class="dv__title" id="dv-heading">
        Tres disciplinas.<br />
        <span class="text-gradient-gold">Un resultado.</span>
      </h2>
      <p class="dv__sub">
        No vendemos tecnología. Vendemos clientes nuevos para tu negocio.
      </p>
    </div>

    <div class="dv__grid">
      {features.map((f, i) => (
        <article
          class="dv__card gs-fade-up"
          style={`animation-delay: ${i * 80}ms; --accent: ${f.accentColor}`}
          aria-label={f.label}
        >
          <!-- Imagen con overlay -->
          <div class="dv__img-wrap">
            <img
              src={f.img}
              alt={f.imgAlt}
              class="dv__img"
              loading="lazy"
              decoding="async"
              width="800"
              height="500"
              onerror="this.style.display='none'"
            />
            <div class="dv__img-overlay" style={`--accent: ${f.accentColor}`}></div>

            <!-- Métrica flotante -->
            <div class="dv__metric">
              <span class="dv__metric-value">{f.metric}</span>
              <span class="dv__metric-label">{f.metricLabel}</span>
            </div>

            <!-- Label chip -->
            <div class="dv__chip">
              <Fragment set:html={f.icon} />
              {f.label}
            </div>
          </div>

          <!-- Copy -->
          <div class="dv__copy">
            <h3 class="dv__copy-title">{f.title}</h3>
            <p class="dv__copy-desc">{f.description}</p>
          </div>
        </article>
      ))}
    </div>

  </div>
</section>

<script>
  import { initScrollReveal } from '../../utils/animations';
  initScrollReveal();
</script>

<style>
  .dv {
    background-color: var(--color-bg-surface);
  }

  .dv__header {
    text-align: center;
    margin-bottom: var(--space-12);
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: var(--space-4);
  }

  .dv__title {
    font-size: clamp(var(--text-3xl), 4vw, var(--text-5xl));
    font-weight: var(--weight-extrabold);
    line-height: var(--leading-tight);
  }

  .dv__sub {
    font-size: var(--text-base);
    color: var(--color-text-secondary);
    max-width: 420px;
    line-height: var(--leading-relaxed);
  }

  /* Grid */
  .dv__grid {
    display: grid;
    grid-template-columns: 1fr;
    gap: var(--space-6);
  }

  @media (min-width: 768px) {
    .dv__grid {
      grid-template-columns: repeat(3, 1fr);
    }
  }

  /* Card */
  .dv__card {
    background-color: var(--color-bg);
    border: 1px solid var(--color-border);
    border-radius: var(--radius-xl);
    overflow: hidden;
    display: flex;
    flex-direction: column;
    transition: transform var(--transition-slow), border-color var(--transition-base), box-shadow var(--transition-slow);
  }

  .dv__card:hover {
    transform: translateY(-6px);
    border-color: var(--color-border-hover);
    box-shadow: var(--shadow-card);
  }

  /* Imagen */
  .dv__img-wrap {
    position: relative;
    height: 200px;
    overflow: hidden;
    background: linear-gradient(135deg, color-mix(in srgb, var(--accent) 30%, #0d0d1a) 0%, #0d0d1a 100%);
  }

  .dv__img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    object-position: center;
    display: block;
    transition: transform 0.6s ease;
  }

  .dv__card:hover .dv__img {
    transform: scale(1.05);
  }

  .dv__img-overlay {
    position: absolute;
    inset: 0;
    background: linear-gradient(
      to bottom,
      rgba(6, 6, 15, 0.15) 0%,
      color-mix(in srgb, var(--accent) 20%, rgba(6,6,15,0.7)) 60%,
      rgba(6, 6, 15, 0.92) 100%
    );
  }

  /* Métrica flotante */
  .dv__metric {
    position: absolute;
    bottom: var(--space-4);
    right: var(--space-4);
    text-align: right;
  }

  .dv__metric-value {
    display: block;
    font-family: var(--font-headline);
    font-size: var(--text-3xl);
    font-weight: var(--weight-extrabold);
    color: #ffffff;
    line-height: 1;
    text-shadow: 0 2px 8px rgba(0,0,0,0.4);
  }

  .dv__metric-label {
    display: block;
    font-size: 10px;
    color: rgba(255,255,255,0.65);
    text-transform: uppercase;
    letter-spacing: 0.05em;
    margin-top: 2px;
  }

  /* Chip label */
  .dv__chip {
    position: absolute;
    top: var(--space-4);
    left: var(--space-4);
    display: inline-flex;
    align-items: center;
    gap: var(--space-2);
    background: rgba(255,255,255,0.12);
    backdrop-filter: blur(8px);
    border: 1px solid rgba(255,255,255,0.18);
    border-radius: var(--radius-full);
    padding: var(--space-1) var(--space-3);
    font-size: var(--text-xs);
    font-weight: var(--weight-semibold);
    color: #ffffff;
    letter-spacing: var(--tracking-wide);
  }

  /* Copy */
  .dv__copy {
    padding: var(--space-5);
    display: flex;
    flex-direction: column;
    gap: var(--space-2);
    flex: 1;
  }

  .dv__copy-title {
    font-family: var(--font-headline);
    font-size: var(--text-lg);
    font-weight: var(--weight-bold);
    color: var(--color-text-primary);
    line-height: var(--leading-snug);
    white-space: pre-line;
  }

  .dv__copy-desc {
    font-size: var(--text-sm);
    color: var(--color-text-secondary);
    line-height: var(--leading-relaxed);
  }
</style>
