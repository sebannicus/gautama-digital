---
/**
 * TrustedBy.astro
 * Propósito: "Han confiado en mí" — clientes reales con testimonio.
 */

const clients = [
  {
    name: 'CheckVital',
    desc: 'Salud & Bienestar · La Serena',
    quote: 'Quería impulsar mi negocio y gracias a la asesoría de Seba entendí lo que necesitaba. Lo aplicamos y hoy recibo constantemente pacientes nuevos sin haber pagado por publicidad, solo posicionamiento de mi web y mi GMB.',
    href: 'https://checkvital.cl',
    initial: 'E',
  },
  {
    name: 'Vital Airpower',
    desc: 'Ingeniería Industrial · Coquimbo',
    quote: 'Necesitábamos una presencia digital que estuviera a la altura de la calidad de nuestros proyectos. Seba entendió nuestro rubro desde el principio y construyó una web que representa exactamente lo que somos como empresa.',
    href: 'https://vital-airpower.vercel.app',
    initial: 'R',
  },
  {
    name: 'SIMA Ingeniería',
    desc: 'Ingeniería · Coquimbo',
    quote: 'Necesitábamos traspasar toda nuestra experiencia a una web que pudiera informar claramente a nuestros clientes. Seba lo logró adoptando una imagen corporativa pero novedosa y además de estar presentes en los buscadores ahora podemos medir todo nuestro tráfico.',
    href: null,
    initial: 'S',
  },
  {
    name: 'Antocarz',
    desc: 'Car Audio & Accesorios · Coquimbo',
    quote: 'Queríamos renovar nuestra imagen y conocer el comportamiento de nuestros clientes. Seba dio en el clavo con una web informando nuestros principales servicios y pudiendo medir su impacto con analíticas.',
    href: 'https://antocarz.vercel.app',
    initial: 'A',
  },
  {
    name: 'Salvatierra Paintworks',
    desc: 'Pintura Profesional · IV Región',
    quote: 'Necesitaba que mis clientes me encontraran fácil en internet y que el sitio transmitiera profesionalismo. Seba construyó exactamente eso — ahora me llegan consultas directas desde la web.',
    href: null,
    initial: 'S',
  },
  {
    name: 'Constructora Scheidl',
    desc: 'Construcción · IV Región',
    quote: 'Queríamos un sitio que reflejara la seriedad y experiencia de nuestra constructora. Seba entregó un resultado corporativo y moderno que nos ha abierto puertas con clientes nuevos.',
    href: null,
    initial: 'C',
  },
];
---

<section class="trusted section" id="clientes" aria-labelledby="trusted-heading">
  <div class="container">

    <div class="trusted__header" data-scroll-children>
      <p class="trusted__label">HAN CONFIADO EN MÍ</p>
      <h2 class="trusted__title" id="trusted-heading">
        Negocios reales.<br />
        <span class="text-gradient-gold">Resultados verificables.</span>
      </h2>
    </div>

    <div class="trusted__grid">
      {clients.map((c, i) => (
        <article
          class="trusted__card shimmer-border gs-fade-up"
          style={`animation-delay: ${i * 80}ms`}
          aria-label={c.name}
        >
          <!-- Header del card -->
          <div class="trusted__card-header">
            <div class="trusted__card-avatar" aria-hidden="true">{c.initial}</div>
            <div class="trusted__card-info">
              <span class="trusted__card-name">{c.name}</span>
              <span class="trusted__card-desc">{c.desc}</span>
            </div>
          </div>

          <!-- Quote -->
          <blockquote class="trusted__card-quote">
            <p>"{c.quote}"</p>
          </blockquote>

          <!-- Link al sitio -->
          {c.href && (
            <a
              href={c.href}
              class="trusted__card-link"
              target="_blank"
              rel="noopener noreferrer"
              aria-label={`Ver sitio de ${c.name}`}
            >
              Ver sitio
              <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true">
                <path d="M7 17L17 7M17 7H7M17 7v10"/>
              </svg>
            </a>
          )}
        </article>
      ))}
    </div>

  </div>
</section>

<script>
  import { initScrollReveal } from '../../utils/animations';
  initScrollReveal();
</script>

<style>
  .trusted {
    background-color: var(--color-bg-surface);
  }

  .trusted__header {
    text-align: center;
    margin-bottom: var(--space-12);
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: var(--space-4);
  }

  .trusted__label {
    font-family: var(--font-subhead);
    font-size: var(--text-xs);
    font-weight: var(--weight-bold);
    letter-spacing: var(--tracking-widest);
    text-transform: uppercase;
    color: var(--color-gold);
  }

  .trusted__title {
    font-size: clamp(var(--text-3xl), 4vw, var(--text-5xl));
    font-weight: var(--weight-extrabold);
    line-height: var(--leading-tight);
  }

  .trusted__grid {
    display: grid;
    grid-template-columns: 1fr;
    gap: var(--space-6);
  }

  @media (min-width: 640px) {
    .trusted__grid {
      grid-template-columns: repeat(2, 1fr);
    }
  }

  @media (min-width: 1024px) {
    .trusted__grid {
      grid-template-columns: repeat(3, 1fr);
    }
  }

  @media (min-width: 1280px) {
    .trusted__grid {
      grid-template-columns: repeat(3, 1fr);
    }
  }

  .trusted__card {
    background-color: var(--color-bg);
    border: 1px solid var(--color-border);
    border-radius: var(--radius-xl);
    padding: var(--space-6);
    display: flex;
    flex-direction: column;
    gap: var(--space-4);
    transition: transform var(--transition-slow), box-shadow var(--transition-slow), border-color var(--transition-base);
  }

  .trusted__card:hover {
    transform: translateY(-4px);
    box-shadow: var(--shadow-gold-hover);
    border-color: var(--color-border-hover);
  }

  .trusted__card-header {
    display: flex;
    align-items: center;
    gap: var(--space-3);
  }

  .trusted__card-avatar {
    width: 42px;
    height: 42px;
    border-radius: 50%;
    background: linear-gradient(135deg, var(--color-gold), var(--color-gold-light));
    color: var(--color-text-inverse);
    font-family: var(--font-headline);
    font-weight: var(--weight-bold);
    font-size: var(--text-base);
    display: flex;
    align-items: center;
    justify-content: center;
    flex-shrink: 0;
  }

  .trusted__card-info {
    display: flex;
    flex-direction: column;
    gap: 2px;
  }

  .trusted__card-name {
    font-family: var(--font-headline);
    font-size: var(--text-base);
    font-weight: var(--weight-bold);
    color: var(--color-text-primary);
  }

  .trusted__card-desc {
    font-size: var(--text-xs);
    color: var(--color-text-muted);
  }

  .trusted__card-quote {
    flex: 1;
    font-size: var(--text-sm);
    line-height: var(--leading-relaxed);
    color: var(--color-text-secondary);
    font-style: normal;
    padding-top: var(--space-2);
    border-top: 1px solid var(--color-border);
  }

  .trusted__card-link {
    display: inline-flex;
    align-items: center;
    gap: var(--space-1);
    font-family: var(--font-subhead);
    font-size: var(--text-xs);
    font-weight: var(--weight-semibold);
    color: var(--color-gold);
    text-decoration: none;
    letter-spacing: var(--tracking-wide);
    transition: gap var(--transition-base);
  }

  .trusted__card-link:hover {
    gap: var(--space-2);
  }
</style>
