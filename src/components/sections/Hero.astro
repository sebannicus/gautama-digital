---
/**
 * Hero.astro
 * Propósito: Sección héroe — primera impresión, impacto máximo.
 * SEO: H1 contiene "La Serena" + "Google" (keyword principal).
 * Animación: GSAP initHeroAnimation() en carga.
 * Visual: fondo negro con glows flotantes dorado/violeta.
 */

import Button from '../ui/Button.astro';
import { SITE } from '../../content/site';

const whatsappMsg = encodeURIComponent('Hola Seba, quiero cotizar mi sitio web. ¿Tienes disponibilidad?');
const whatsappUrl = `https://wa.me/${SITE.whatsapp}?text=${whatsappMsg}`;
---

<section class="hero" id="inicio" aria-label="Inicio">
  <!-- Glows decorativos de fondo -->
  <div class="bg-glow bg-glow--gold hero__glow hero__glow--1" aria-hidden="true"></div>
  <div class="bg-glow bg-glow--violet hero__glow hero__glow--2" aria-hidden="true"></div>
  <div class="bg-glow bg-glow--violet hero__glow hero__glow--3" aria-hidden="true"></div>

  <div class="container hero__inner">
    <div class="hero__content" id="hero-parallax">
      <!-- Label superior -->
      <span class="hero__label" data-hero-label>
        <span class="hero__label-dot" aria-hidden="true"></span>
        Diseño Web & SEO Local — {SITE.location.city}
      </span>

      <!-- H1 — keyword principal incluida -->
      <h1 class="hero__title" data-hero-title>
        Tu negocio en La Serena,<br />
        <span class="text-gradient-gold">visible en Google</span><br />
        desde el día uno.
      </h1>

      <!-- Subtítulo -->
      <p class="hero__sub" data-hero-sub>
        Diseño web profesional y SEO real para negocios locales en La Serena y Coquimbo.
        Sin agencias impersonales. Sin mensualidades obligatorias. Solo resultados.
      </p>

      <!-- CTAs -->
      <div class="hero__cta" data-hero-cta>
        <Button href={whatsappUrl} variant="primary" size="lg" external={true} pulse={true}>
          Habla con Seba →
        </Button>
      </div>

      <!-- Prueba social rápida -->
      <div class="hero__proof" data-hero-cta>
        <div class="hero__proof-item">
          <span class="hero__proof-value">+100</span>
          <span class="hero__proof-label">visitas orgánicas en 30 días</span>
        </div>
        <span class="hero__proof-divider" aria-hidden="true">·</span>
        <div class="hero__proof-item">
          <span class="hero__proof-value">$0</span>
          <span class="hero__proof-label">en publicidad</span>
        </div>
        <span class="hero__proof-divider" aria-hidden="true">·</span>
        <div class="hero__proof-item">
          <span class="hero__proof-value">Top Maps</span>
          <span class="hero__proof-label">Google Maps local</span>
        </div>
      </div>
    </div>
  </div>

  <!-- Marquee ticker — da vida y refuerza keywords SEO -->
  <div class="hero__marquee marquee" aria-hidden="true">
    <div class="marquee__track">
      <span class="hero__marquee-item">Diseño Web Profesional</span>
      <span class="hero__marquee-sep">·</span>
      <span class="hero__marquee-item">SEO Local</span>
      <span class="hero__marquee-sep">·</span>
      <span class="hero__marquee-item">Google Maps</span>
      <span class="hero__marquee-sep">·</span>
      <span class="hero__marquee-item">La Serena</span>
      <span class="hero__marquee-sep">·</span>
      <span class="hero__marquee-item">Coquimbo</span>
      <span class="hero__marquee-sep">·</span>
      <span class="hero__marquee-item">Posicionamiento Google</span>
      <span class="hero__marquee-sep">·</span>
      <span class="hero__marquee-item">Sin Mensualidades</span>
      <span class="hero__marquee-sep">·</span>
      <span class="hero__marquee-item">Resultados Reales</span>
      <span class="hero__marquee-sep">·</span>
      <!-- Duplicado para loop continuo -->
      <span class="hero__marquee-item">Diseño Web Profesional</span>
      <span class="hero__marquee-sep">·</span>
      <span class="hero__marquee-item">SEO Local</span>
      <span class="hero__marquee-sep">·</span>
      <span class="hero__marquee-item">Google Maps</span>
      <span class="hero__marquee-sep">·</span>
      <span class="hero__marquee-item">La Serena</span>
      <span class="hero__marquee-sep">·</span>
      <span class="hero__marquee-item">Coquimbo</span>
      <span class="hero__marquee-sep">·</span>
      <span class="hero__marquee-item">Posicionamiento Google</span>
      <span class="hero__marquee-sep">·</span>
      <span class="hero__marquee-item">Sin Mensualidades</span>
      <span class="hero__marquee-sep">·</span>
      <span class="hero__marquee-item">Resultados Reales</span>
      <span class="hero__marquee-sep">·</span>
    </div>
  </div>

  <!-- Scroll hint -->
  <div class="hero__scroll" data-hero-scroll aria-hidden="true">
    <div class="hero__scroll-line"></div>
    <span class="hero__scroll-text">Scroll</span>
  </div>
</section>

<script>
  import { initHeroAnimation } from '../../utils/animations';
  initHeroAnimation();

  // Efecto scroll-scale: el contenido se reduce suavemente al bajar
  const heroParallax = document.getElementById('hero-parallax');
  if (heroParallax && window.matchMedia('(prefers-reduced-motion: no-preference)').matches) {
    window.addEventListener('scroll', () => {
      const scrollY = window.scrollY;
      const scale = Math.max(1 - scrollY / 1400, 0.88);
      const opacity = Math.max(1 - scrollY / 500, 0);
      heroParallax.style.transform = `scale(${scale})`;
      heroParallax.style.opacity = String(opacity);
    }, { passive: true });
  }
</script>

<style>
  .hero {
    position: relative;
    min-height: 100dvh;
    display: flex;
    align-items: center;
    overflow: hidden;
    padding-top: 100px;
    padding-bottom: var(--space-20);
  }

  /* Glows */
  .hero__glow {
    pointer-events: none;
  }

  .hero__glow--1 {
    width: 700px;
    height: 700px;
    top: -150px;
    right: -250px;
  }

  .hero__glow--2 {
    width: 600px;
    height: 600px;
    bottom: 0;
    left: -200px;
    animation-delay: -6s;
  }

  .hero__glow--3 {
    width: 400px;
    height: 400px;
    top: 40%;
    right: 15%;
    animation-delay: -10s;
    opacity: 0.12;
  }

  /* Layout */
  .hero__inner {
    position: relative;
    z-index: var(--z-above);
  }

  .hero__content {
    max-width: 780px;
    display: flex;
    flex-direction: column;
    gap: var(--space-6);
  }

  /* Label */
  .hero__label {
    display: inline-flex;
    align-items: center;
    gap: var(--space-2);
    font-family: var(--font-subhead);
    font-size: var(--text-sm);
    font-weight: var(--weight-medium);
    letter-spacing: var(--tracking-wide);
    color: var(--color-text-secondary);
    opacity: 0; /* GSAP lo activa */
  }

  .hero__label-dot {
    width: 8px;
    height: 8px;
    background: var(--color-gold);
    border-radius: 50%;
    flex-shrink: 0;
    animation: pulse-gold 2s ease-in-out infinite;
  }

  /* H1 */
  .hero__title {
    font-family: var(--font-headline);
    font-size: clamp(var(--text-4xl), 6vw, var(--text-7xl));
    font-weight: var(--weight-extrabold);
    line-height: var(--leading-tight);
    letter-spacing: var(--tracking-tight);
    color: var(--color-text-primary);
    opacity: 0; /* GSAP */
  }

  /* Subtítulo */
  .hero__sub {
    font-size: clamp(var(--text-base), 2vw, var(--text-lg));
    color: var(--color-text-secondary);
    line-height: var(--leading-relaxed);
    max-width: 580px;
    opacity: 0; /* GSAP */
  }

  /* CTAs */
  .hero__cta {
    display: flex;
    flex-wrap: wrap;
    gap: var(--space-4);
    align-items: center;
    opacity: 0; /* GSAP */
  }

  /* Prueba social */
  .hero__proof {
    display: flex;
    flex-wrap: wrap;
    align-items: center;
    gap: var(--space-3);
    padding-top: var(--space-4);
    border-top: 1px solid var(--color-border);
    opacity: 0; /* GSAP */
  }

  /* Marquee */
  .hero__marquee {
    position: absolute;
    bottom: var(--space-20);
    left: 0;
    right: 0;
    padding-block: var(--space-3);
    border-top: 1px solid var(--color-border);
    border-bottom: 1px solid var(--color-border);
  }

  .hero__marquee-item {
    font-family: var(--font-subhead);
    font-size: var(--text-sm);
    font-weight: var(--weight-semibold);
    letter-spacing: var(--tracking-wide);
    text-transform: uppercase;
    color: var(--color-text-secondary);
    flex-shrink: 0;
  }

  .hero__marquee-sep {
    color: var(--color-violet-dim);
    font-size: var(--text-base);
    flex-shrink: 0;
  }

  .hero__proof-item {
    display: flex;
    flex-direction: column;
    gap: 2px;
  }

  .hero__proof-value {
    font-family: var(--font-headline);
    font-size: var(--text-lg);
    font-weight: var(--weight-bold);
    color: var(--color-gold);
    line-height: 1;
    background: linear-gradient(135deg, var(--color-gold), var(--color-gold-light));
    -webkit-background-clip: text;
    -webkit-text-fill-color: transparent;
    background-clip: text;
  }

  .hero__proof-label {
    font-size: var(--text-xs);
    color: var(--color-text-muted);
  }

  .hero__proof-divider {
    color: var(--color-text-muted);
    font-size: var(--text-xl);
  }

  /* Scroll hint */
  .hero__scroll {
    position: absolute;
    bottom: var(--space-4);
    left: 50%;
    transform: translateX(-50%);
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: var(--space-2);
    opacity: 0; /* GSAP */
  }

  .hero__scroll-line {
    width: 1px;
    height: 48px;
    background: linear-gradient(to bottom, var(--color-gold), transparent);
    animation: scroll-line 2s ease-in-out infinite;
  }

  @keyframes scroll-line {
    0% { transform: scaleY(0); transform-origin: top; }
    50% { transform: scaleY(1); transform-origin: top; }
    51% { transform: scaleY(1); transform-origin: bottom; }
    100% { transform: scaleY(0); transform-origin: bottom; }
  }

  .hero__scroll-text {
    font-family: var(--font-subhead);
    font-size: var(--text-xs);
    letter-spacing: var(--tracking-widest);
    text-transform: uppercase;
    color: var(--color-text-muted);
  }

  @media (max-width: 640px) {
    .hero__scroll {
      display: none;
    }

    .hero__cta {
      flex-direction: column;
      align-items: flex-start;
    }

    .hero__cta :global(.btn) {
      width: 100%;
      justify-content: center;
    }
  }
</style>
