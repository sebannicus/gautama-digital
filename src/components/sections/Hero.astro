---
/**
 * Hero.astro
 * Propósito: Primera impresión — impacto máximo, mínimo texto.
 * Visual: texto izquierda + card de Google ranking derecha (desktop).
 */

import Button from '../ui/Button.astro';
import { SITE } from '../../content/site';

const whatsappMsg = encodeURIComponent('Hola Seba, quiero solicitar una cotización para mi negocio. ¿Tienes disponibilidad?');
const whatsappUrl = `https://wa.me/${SITE.whatsapp}?text=${whatsappMsg}`;
---

<section class="hero" id="inicio" aria-label="Inicio">
  <div class="bg-glow bg-glow--gold hero__glow hero__glow--1" aria-hidden="true"></div>
  <div class="bg-glow bg-glow--violet hero__glow hero__glow--2" aria-hidden="true"></div>

  <!-- Video decorativo — lado derecho, solo desktop -->
  <div class="hero__video-wrap" aria-hidden="true">
    <video
      class="hero__video"
      src="/images/hero-video.mp4"
      autoplay
      muted
      loop
      playsinline
      preload="auto"
    ></video>
    <div class="hero__video-fade"></div>
  </div>

  <div class="container hero__inner">

    <!-- Contenido -->
    <div class="hero__content" id="hero-parallax">
      <span class="hero__label" data-hero-label>
        <span class="hero__label-dot" aria-hidden="true"></span>
        Para negocios en La Serena y Coquimbo
      </span>

      <h1 class="hero__title" data-hero-title>
        Tu negocio en Google.<br />
        <span class="text-gradient-gold">Sin pagar publicidad.</span>
      </h1>

      <p class="hero__sub" data-hero-sub>
        Diseño web profesional + SEO local + Google My Business — desde $280.000 CLP.
      </p>

      <div class="hero__cta" data-hero-cta>
        <Button href={whatsappUrl} variant="primary" size="lg" external={true} pulse={true}>
          Cotización gratis
        </Button>
        <Button href="/servicios" variant="ghost" size="lg">
          Ver planes →
        </Button>
      </div>

      <!-- Prueba social: 3 datos en pills -->
      <div class="hero__proof" data-hero-cta>
        <div class="hero__proof-pill">
          <span class="hero__proof-val">+100</span>
          <span class="hero__proof-lbl">visitas / 30 días</span>
        </div>
        <div class="hero__proof-pill">
          <span class="hero__proof-val">$0</span>
          <span class="hero__proof-lbl">en publicidad</span>
        </div>
        <div class="hero__proof-pill">
          <span class="hero__proof-val">#1</span>
          <span class="hero__proof-lbl">Google Maps</span>
        </div>
      </div>
    </div>

  </div>

  <!-- Marquee -->
  <div class="hero__marquee marquee" aria-hidden="true">
    <div class="marquee__track">
      {['Diseño Web La Serena','SEO Local','Google Maps','Marketing Digital','Coquimbo','Sitios a Medida','Sin Publicidad Pagada','Optimización Web','Diseño Web La Serena','SEO Local','Google Maps','Marketing Digital','Coquimbo','Sitios a Medida','Sin Publicidad Pagada','Optimización Web'].map(item =>
        item.startsWith('Diseño') || item.startsWith('SEO') || item.startsWith('Google') || item.startsWith('Mar') || item.startsWith('Coq') || item.startsWith('Sit') || item.startsWith('Sin') || item.startsWith('Opt')
          ? <><span class="hero__marquee-item">{item}</span><span class="hero__marquee-sep">·</span></>
          : null
      )}
    </div>
  </div>

  <div class="hero__scroll" data-hero-scroll aria-hidden="true">
    <div class="hero__scroll-line"></div>
    <span class="hero__scroll-text">Scroll</span>
  </div>
</section>

<script>
  import { initHeroAnimation } from '../../utils/animations';
  initHeroAnimation();

  // Fade suave en el corte del loop del video
  const heroVideo = document.querySelector<HTMLVideoElement>('.hero__video');
  if (heroVideo) {
    const FADE = 0.6;
    const MAX_OP = 0.75;
    heroVideo.addEventListener('timeupdate', () => {
      const { currentTime, duration } = heroVideo;
      if (!duration) return;
      const remaining = duration - currentTime;
      if (remaining < FADE) {
        heroVideo.style.opacity = String((remaining / FADE) * MAX_OP);
      } else if (currentTime < FADE) {
        heroVideo.style.opacity = String((currentTime / FADE) * MAX_OP);
      } else {
        heroVideo.style.opacity = String(MAX_OP);
      }
    });
  }

  const heroParallax = document.getElementById('hero-parallax');
  if (heroParallax && window.matchMedia('(prefers-reduced-motion: no-preference)').matches) {
    window.addEventListener('scroll', () => {
      const s = window.scrollY;
      heroParallax.style.transform = `scale(${Math.max(1 - s / 1400, 0.88)})`;
      heroParallax.style.opacity = String(Math.max(1 - s / 500, 0));
    }, { passive: true });
  }
</script>

<style>
  .hero {
    /* Fusión oscura — igual que producción */
    --hero-bg: #06060F;
    position: relative;
    min-height: 100dvh;
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    overflow: hidden;
    padding-top: 100px;
    padding-bottom: var(--space-20);
    background-color: var(--hero-bg);
  }

  .hero__glow { pointer-events: none; }
  .hero__glow--1 { width: 700px; height: 700px; top: -150px; right: -200px; }
  .hero__glow--2 { width: 500px; height: 500px; bottom: 0; left: -200px; animation-delay: -6s; }

  .hero__inner {
    position: relative;
    z-index: var(--z-above);
  }

  .hero__content {
    max-width: 780px;
    display: flex;
    flex-direction: column;
    gap: var(--space-6);
    padding-bottom: 140px;
  }

  /* Video hero */
  .hero__video-wrap {
    display: none;
  }

  @media (min-width: 1024px) {
    .hero__video-wrap {
      display: block;
      position: absolute;
      top: 0;
      right: 0;
      width: 52%;
      height: 100%;
      overflow: hidden;
      pointer-events: none;
    }

    .hero__video {
      width: 100%;
      height: 100%;
      object-fit: cover;
      object-position: center;
      opacity: 0;
      transition: opacity 0.05s linear;
    }

    .hero__video-fade {
      position: absolute;
      inset: 0;
      background:
        linear-gradient(to right,  var(--hero-bg) 0%, var(--hero-bg) 8%, transparent 58%),
        linear-gradient(to top,    var(--hero-bg) 0%, transparent 28%),
        linear-gradient(to bottom, var(--hero-bg) 0%, transparent 18%);
    }
  }

  .hero__label {
    display: inline-flex;
    align-items: center;
    gap: var(--space-2);
    font-family: var(--font-subhead);
    font-size: var(--text-sm);
    font-weight: var(--weight-medium);
    letter-spacing: var(--tracking-wide);
    color: rgba(255,255,255,0.55);
    opacity: 0;
  }

  .hero__label-dot {
    width: 8px; height: 8px;
    background: var(--color-gold);
    border-radius: 50%;
    flex-shrink: 0;
    animation: pulse-gold 2s ease-in-out infinite;
  }

  .hero__title {
    font-family: var(--font-headline);
    font-size: clamp(var(--text-4xl), 5.5vw, var(--text-6xl));
    font-weight: var(--weight-extrabold);
    line-height: var(--leading-tight);
    letter-spacing: var(--tracking-tight);
    color: #ffffff;
    opacity: 0;
  }

  .hero__sub {
    font-size: clamp(var(--text-base), 1.8vw, var(--text-lg));
    color: rgba(255,255,255,0.65);
    line-height: var(--leading-relaxed);
    max-width: 480px;
    opacity: 0;
  }

  .hero__cta {
    display: flex;
    flex-wrap: wrap;
    gap: var(--space-4);
    align-items: center;
    opacity: 0;
  }

  /* Pills de prueba social */
  .hero__proof {
    display: flex;
    flex-wrap: wrap;
    gap: var(--space-3);
    opacity: 0;
  }

  .hero__proof-pill {
    display: flex;
    align-items: center;
    gap: var(--space-2);
    background: rgba(255,255,255,0.04);
    border: 1px solid rgba(255,255,255,0.09);
    border-radius: var(--radius-full);
    padding: var(--space-2) var(--space-4);
  }

  .hero__proof-val {
    font-family: var(--font-headline);
    font-size: var(--text-base);
    font-weight: var(--weight-extrabold);
    color: var(--color-gold);
  }

  .hero__proof-lbl {
    font-size: var(--text-xs);
    color: rgba(255,255,255,0.42);
    font-family: var(--font-subhead);
    letter-spacing: var(--tracking-wide);
  }

  /* Marquee */
  .hero__marquee {
    position: absolute;
    bottom: var(--space-16);
    left: 0; right: 0;
    padding-block: var(--space-3);
    border-top: 1px solid rgba(255,255,255,0.07);
    border-bottom: 1px solid rgba(255,255,255,0.07);
  }

  .hero__marquee-item {
    font-family: var(--font-subhead);
    font-size: var(--text-sm);
    font-weight: var(--weight-semibold);
    letter-spacing: var(--tracking-wide);
    text-transform: uppercase;
    color: rgba(255,255,255,0.38);
    flex-shrink: 0;
  }

  .hero__marquee-sep { color: rgba(4,196,217,0.45); flex-shrink: 0; }

  /* Scroll hint */
  .hero__scroll {
    position: absolute;
    bottom: var(--space-4);
    left: 50%; transform: translateX(-50%);
    display: flex; flex-direction: column;
    align-items: center; gap: var(--space-2);
    opacity: 0;
  }

  .hero__scroll-line {
    width: 1px; height: 48px;
    background: linear-gradient(to bottom, var(--color-gold), transparent);
    animation: scroll-line 2s ease-in-out infinite;
  }

  @keyframes scroll-line {
    0%   { transform: scaleY(0); transform-origin: top; }
    50%  { transform: scaleY(1); transform-origin: top; }
    51%  { transform: scaleY(1); transform-origin: bottom; }
    100% { transform: scaleY(0); transform-origin: bottom; }
  }

  .hero__scroll-text {
    font-family: var(--font-subhead);
    font-size: var(--text-xs);
    letter-spacing: var(--tracking-widest);
    text-transform: uppercase;
    color: rgba(255,255,255,0.35);
  }

  @media (max-width: 640px) {
    .hero__scroll { display: none; }
    .hero__cta { flex-direction: column; align-items: flex-start; }
    .hero__cta :global(.btn) { width: 100%; justify-content: center; }
  }
</style>
