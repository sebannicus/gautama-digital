---
/**
 * BlogPreview.astro
 * Propósito: Vista previa del blog en la página principal.
 * Layout: primer artículo featured (ancho completo), dos más abajo en grid.
 * Relación: consume BLOG_POSTS de content/blog.ts.
 */

import SectionLabel from '../ui/SectionLabel.astro';
import { BLOG_POSTS } from '../../content/blog';

const [featured, ...rest] = BLOG_POSTS.slice(0, 3);

function formatDate(iso: string): string {
  const [year, month, day] = iso.split('-').map(Number);
  const months = ['Ene', 'Feb', 'Mar', 'Abr', 'May', 'Jun', 'Jul', 'Ago', 'Sep', 'Oct', 'Nov', 'Dic'];
  return `${day} ${months[month - 1]} ${year}`;
}

/* Íconos SVG por categoría */
const categoryIcons: Record<string, string> = {
  'Diseño Web':
    `<rect x="2" y="3" width="20" height="14" rx="2"/><line x1="8" y1="21" x2="16" y2="21"/><line x1="12" y1="17" x2="12" y2="21"/>`,
  'SEO Local':
    `<circle cx="11" cy="11" r="8"/><path d="M21 21l-4.35-4.35"/><path d="M11 8a3 3 0 100 6 3 3 0 000-6z"/>`,
  'Automatización IA':
    `<rect x="3" y="11" width="18" height="10" rx="2"/><circle cx="12" cy="5" r="3"/><line x1="12" y1="8" x2="12" y2="11"/><line x1="8" y1="15" x2="8" y2="15"/><line x1="12" y1="15" x2="12" y2="15"/><line x1="16" y1="15" x2="16" y2="15"/>`,
};

function getIcon(category: string): string {
  return categoryIcons[category] ?? categoryIcons['Diseño Web'];
}
---

<section class="blog-preview section" id="blog" aria-labelledby="blog-heading">
  <div class="container">

    <div class="blog-preview__header" data-scroll-children>
      <SectionLabel text="BLOG" align="center" />
      <h2 class="blog-preview__title" id="blog-heading">
        Aprende a hacer crecer<br />
        <span class="text-gradient-gold">tu negocio digital.</span>
      </h2>
      <p class="blog-preview__sub">
        Guías prácticas sobre diseño web, SEO local e inteligencia artificial — pensadas para negocios en Chile.
      </p>
    </div>

    <!-- Artículo Featured -->
    <a
      href={`/blog/${featured.slug}`}
      class="blog-featured gs-fade-up"
      aria-label={`Leer: ${featured.title}`}
    >
      <!-- Visual izquierda -->
      <div
        class="blog-featured__visual"
        style={`--from: ${featured.gradientFrom}; --to: ${featured.gradientTo};`}
        aria-hidden="true"
      >
        <!-- Patrón de puntos decorativo -->
        <div class="blog-featured__dots"></div>

        <!-- Ícono central grande -->
        <div class="blog-featured__icon">
          <svg width="48" height="48" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true" set:html={getIcon(featured.category)} />
        </div>

        <!-- Badge DESTACADO -->
        <span class="blog-featured__badge">Destacado</span>

        <!-- Glow interior -->
        <div class="blog-featured__glow" aria-hidden="true"></div>
      </div>

      <!-- Contenido derecha -->
      <div class="blog-featured__body">
        <div class="blog-featured__meta">
          <span class="blog-featured__cat" style={`background: ${featured.categoryColor}18; color: ${featured.categoryColor}; border-color: ${featured.categoryColor}35;`}>
            {featured.category}
          </span>
          <span class="blog-featured__sep" aria-hidden="true">·</span>
          <time datetime={featured.publishedAt} class="blog-featured__date">{formatDate(featured.publishedAt)}</time>
          <span class="blog-featured__sep" aria-hidden="true">·</span>
          <span class="blog-featured__read">{featured.readTime} min</span>
        </div>

        <h3 class="blog-featured__title">{featured.title}</h3>
        <p class="blog-featured__excerpt">{featured.excerpt}</p>

        <span class="blog-featured__link">
          Leer artículo
          <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true">
            <path d="M5 12h14M12 5l7 7-7 7"/>
          </svg>
        </span>
      </div>
    </a>

    <!-- Grid secundario -->
    <div class="blog-grid">
      {rest.map((post, i) => (
        <a
          href={`/blog/${post.slug}`}
          class="blog-card gs-fade-up"
          style={`animation-delay: ${(i + 1) * 80}ms`}
          aria-label={`Leer: ${post.title}`}
        >
          <!-- Visual superior -->
          <div
            class="blog-card__visual"
            style={`--from: ${post.gradientFrom}; --to: ${post.gradientTo};`}
            aria-hidden="true"
          >
            <div class="blog-card__icon">
              <svg width="32" height="32" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true" set:html={getIcon(post.category)} />
            </div>
            <div class="blog-card__visual-glow"></div>
            <!-- Líneas decorativas -->
            <div class="blog-card__lines" aria-hidden="true">
              <span></span><span></span><span></span>
            </div>
          </div>

          <!-- Body -->
          <div class="blog-card__body">
            <div class="blog-card__meta">
              <span class="blog-card__cat" style={`color: ${post.categoryColor};`}>{post.category}</span>
              <span class="blog-card__dot" aria-hidden="true">·</span>
              <span class="blog-card__read">{post.readTime} min</span>
            </div>
            <h3 class="blog-card__title">{post.title}</h3>
            <p class="blog-card__excerpt">{post.excerpt}</p>
            <span class="blog-card__link">
              Leer artículo
              <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true">
                <path d="M5 12h14M12 5l7 7-7 7"/>
              </svg>
            </span>
          </div>
        </a>
      ))}
    </div>

  </div>
</section>

<script>
  import { initScrollReveal } from '../../utils/animations';
  initScrollReveal();
</script>

<style>
  .blog-preview {
    background-color: var(--color-bg-surface);
  }

  .blog-preview__header {
    text-align: center;
    margin-bottom: var(--space-12);
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: var(--space-4);
  }

  .blog-preview__title {
    font-size: clamp(var(--text-3xl), 4vw, var(--text-5xl));
    font-weight: var(--weight-extrabold);
    line-height: var(--leading-tight);
  }

  .blog-preview__sub {
    font-size: var(--text-base);
    color: var(--color-text-secondary);
    max-width: 460px;
    line-height: var(--leading-relaxed);
  }

  /* ── Featured Card ── */
  .blog-featured {
    display: flex;
    flex-direction: column;
    background-color: var(--color-bg);
    border: 1px solid var(--color-border);
    border-radius: var(--radius-2xl);
    overflow: hidden;
    margin-bottom: var(--space-6);
    text-decoration: none;
    transition: border-color var(--transition-base), box-shadow var(--transition-slow), transform var(--transition-slow);
  }

  .blog-featured:hover {
    border-color: var(--color-border-hover);
    box-shadow: 0 8px 40px rgba(4, 119, 191, 0.12);
    transform: translateY(-3px);
  }

  /* Visual izquierda del featured */
  .blog-featured__visual {
    position: relative;
    background: linear-gradient(135deg, var(--from), var(--to));
    min-height: 200px;
    display: flex;
    align-items: center;
    justify-content: center;
    overflow: hidden;
    flex-shrink: 0;
  }

  /* Patrón de puntos */
  .blog-featured__dots {
    position: absolute;
    inset: 0;
    background-image: radial-gradient(rgba(255,255,255,0.15) 1px, transparent 1px);
    background-size: 24px 24px;
    pointer-events: none;
  }

  .blog-featured__icon {
    position: relative;
    color: rgba(255,255,255,0.9);
    z-index: 1;
    filter: drop-shadow(0 4px 24px rgba(0,0,0,0.2));
  }

  .blog-featured__badge {
    position: absolute;
    top: var(--space-4);
    left: var(--space-4);
    font-family: var(--font-subhead);
    font-size: 10px;
    font-weight: var(--weight-bold);
    letter-spacing: var(--tracking-widest);
    text-transform: uppercase;
    color: rgba(255,255,255,0.9);
    background: rgba(255,255,255,0.15);
    border: 1px solid rgba(255,255,255,0.25);
    border-radius: var(--radius-full);
    padding: 3px var(--space-3);
    backdrop-filter: blur(6px);
    z-index: 2;
  }

  .blog-featured__glow {
    position: absolute;
    inset: 0;
    background: linear-gradient(160deg, rgba(255,255,255,0.1) 0%, transparent 60%);
    pointer-events: none;
  }

  /* Cuerpo del featured */
  .blog-featured__body {
    padding: var(--space-8);
    display: flex;
    flex-direction: column;
    gap: var(--space-4);
    justify-content: center;
  }

  .blog-featured__meta {
    display: flex;
    flex-wrap: wrap;
    align-items: center;
    gap: var(--space-2);
    font-size: var(--text-xs);
    color: var(--color-text-muted);
    font-family: var(--font-subhead);
    letter-spacing: var(--tracking-wide);
  }

  .blog-featured__cat {
    padding: 2px var(--space-2);
    border: 1px solid;
    border-radius: var(--radius-full);
    font-size: 10px;
    font-weight: var(--weight-semibold);
    letter-spacing: var(--tracking-widest);
    text-transform: uppercase;
  }

  .blog-featured__sep { opacity: 0.4; }

  .blog-featured__title {
    font-family: var(--font-headline);
    font-size: clamp(var(--text-xl), 2.5vw, var(--text-3xl));
    font-weight: var(--weight-bold);
    color: var(--color-text-primary);
    line-height: var(--leading-snug);
  }

  .blog-featured__excerpt {
    font-size: var(--text-sm);
    color: var(--color-text-secondary);
    line-height: var(--leading-relaxed);
    max-width: 520px;
  }

  .blog-featured__link {
    display: inline-flex;
    align-items: center;
    gap: var(--space-2);
    font-family: var(--font-subhead);
    font-size: var(--text-sm);
    font-weight: var(--weight-semibold);
    color: var(--color-gold);
    letter-spacing: var(--tracking-wide);
    transition: gap var(--transition-base);
  }

  .blog-featured:hover .blog-featured__link {
    gap: var(--space-3);
  }

  /* ── Grid secundario ── */
  .blog-grid {
    display: grid;
    grid-template-columns: 1fr;
    gap: var(--space-5);
  }

  @media (min-width: 600px) {
    .blog-grid {
      grid-template-columns: repeat(2, 1fr);
    }
  }

  /* ── Card secundaria ── */
  .blog-card {
    background-color: var(--color-bg);
    border: 1px solid var(--color-border);
    border-radius: var(--radius-xl);
    overflow: hidden;
    display: flex;
    flex-direction: column;
    text-decoration: none;
    transition: border-color var(--transition-base), box-shadow var(--transition-slow), transform var(--transition-slow);
  }

  .blog-card:hover {
    border-color: var(--color-border-hover);
    box-shadow: var(--shadow-card);
    transform: translateY(-3px);
  }

  /* Visual */
  .blog-card__visual {
    position: relative;
    background: linear-gradient(135deg, var(--from), var(--to));
    height: 160px;
    display: flex;
    align-items: center;
    justify-content: center;
    overflow: hidden;
    flex-shrink: 0;
  }

  .blog-card__icon {
    position: relative;
    z-index: 1;
    color: rgba(255,255,255,0.88);
    filter: drop-shadow(0 4px 16px rgba(0,0,0,0.18));
  }

  .blog-card__visual-glow {
    position: absolute;
    inset: 0;
    background: linear-gradient(160deg, rgba(255,255,255,0.12) 0%, transparent 55%);
    pointer-events: none;
  }

  /* Líneas decorativas de fondo */
  .blog-card__lines {
    position: absolute;
    bottom: var(--space-4);
    left: var(--space-4);
    display: flex;
    flex-direction: column;
    gap: 5px;
    opacity: 0.25;
  }

  .blog-card__lines span {
    display: block;
    height: 3px;
    border-radius: var(--radius-full);
    background: white;
  }

  .blog-card__lines span:nth-child(1) { width: 40px; }
  .blog-card__lines span:nth-child(2) { width: 28px; }
  .blog-card__lines span:nth-child(3) { width: 18px; }

  /* Body */
  .blog-card__body {
    padding: var(--space-5);
    display: flex;
    flex-direction: column;
    gap: var(--space-3);
    flex: 1;
  }

  .blog-card__meta {
    display: flex;
    align-items: center;
    gap: var(--space-2);
    font-family: var(--font-subhead);
    font-size: var(--text-xs);
    letter-spacing: var(--tracking-wide);
  }

  .blog-card__cat {
    font-weight: var(--weight-semibold);
    text-transform: uppercase;
    font-size: 10px;
    letter-spacing: var(--tracking-widest);
  }

  .blog-card__dot {
    color: var(--color-text-muted);
    opacity: 0.5;
  }

  .blog-card__read {
    color: var(--color-text-muted);
  }

  .blog-card__title {
    font-family: var(--font-headline);
    font-size: var(--text-base);
    font-weight: var(--weight-bold);
    color: var(--color-text-primary);
    line-height: var(--leading-snug);
  }

  .blog-card__excerpt {
    font-size: var(--text-sm);
    color: var(--color-text-secondary);
    line-height: var(--leading-relaxed);
    flex: 1;
    display: -webkit-box;
    -webkit-line-clamp: 3;
    -webkit-box-orient: vertical;
    overflow: hidden;
  }

  .blog-card__link {
    display: inline-flex;
    align-items: center;
    gap: 5px;
    font-family: var(--font-subhead);
    font-size: var(--text-xs);
    font-weight: var(--weight-semibold);
    color: var(--color-gold);
    letter-spacing: var(--tracking-wide);
    margin-top: auto;
    padding-top: var(--space-3);
    border-top: 1px solid var(--color-border);
    transition: gap var(--transition-base);
  }

  .blog-card:hover .blog-card__link {
    gap: var(--space-2);
  }

  /* ── Responsive desktop: featured horizontal ── */
  @media (min-width: 768px) {
    .blog-featured {
      flex-direction: row;
    }

    .blog-featured__visual {
      width: 380px;
      min-height: 280px;
      flex-shrink: 0;
    }

    .blog-featured__body {
      flex: 1;
      padding: var(--space-10);
    }
  }
</style>
