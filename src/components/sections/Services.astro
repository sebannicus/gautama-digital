---
/**
 * Services.astro
 * Propósito: Sección de paquetes de servicios con pricing transparente.
 * Estrategia SEO: mostrar precios reales — diferenciador vs competencia local.
 * Relación: consume SERVICES, renderiza ServiceCard por cada paquete.
 */

import SectionLabel from '../ui/SectionLabel.astro';
import ServiceCard from '../ui/ServiceCard.astro';
import { SERVICES } from '../../content/services';
---

<section class="services section section--surface" id="servicios" aria-labelledby="services-heading">
  <div class="container">
    <div class="services__header" data-scroll-children>
      <SectionLabel text="PAQUETES" align="center" />
      <h2 class="services__title" id="services-heading">
        Precios claros.<br />
        <span class="text-gradient-gold">Sin letras chicas.</span>
      </h2>
      <p class="services__sub">
        Inviertes una vez. El sitio es tuyo. Sin mensualidades obligatorias ni contratos trampa.
      </p>
    </div>

    <div class="services__cupo gs-fade-in" aria-live="polite">
      <span class="services__cupo-dot" aria-hidden="true"></span>
      Trabajo con máximo <strong>4 clientes al mes</strong>. Actualmente tengo
      <strong>1 cupo disponible</strong>.
    </div>

    <div class="services__grid">
      {SERVICES.map((service) => (
        <ServiceCard service={service} />
      ))}
    </div>

    <p class="services__note gs-fade-in">
      ¿Tienes dudas sobre qué paquete te conviene?
      <a href="#contacto" class="link-gold">Escríbele a Seba</a> — sin compromiso.
    </p>
  </div>
</section>

<style>
  /* Header */
  .services__header {
    text-align: center;
    margin-bottom: var(--space-12);
  }

  .services__title {
    font-size: clamp(var(--text-3xl), 4vw, var(--text-5xl));
    margin-bottom: var(--space-4);
  }

  .services__sub {
    font-size: var(--text-base);
    color: var(--color-text-secondary);
    max-width: 520px;
    margin-inline: auto;
    line-height: var(--leading-relaxed);
  }

  /* Cupo disponible */
  .services__cupo {
    display: flex;
    align-items: center;
    justify-content: center;
    gap: var(--space-2);
    font-size: var(--text-sm);
    color: var(--color-text-secondary);
    margin-bottom: var(--space-8);
    padding: var(--space-3) var(--space-5);
    border: 1px solid var(--color-border-hover);
    border-radius: var(--radius-full);
    width: fit-content;
    margin-inline: auto;
  }

  .services__cupo-dot {
    width: 8px;
    height: 8px;
    background: var(--color-gold);
    border-radius: 50%;
    flex-shrink: 0;
    animation: pulse-gold 2s ease-in-out infinite;
  }

  .services__cupo strong {
    color: var(--color-text-primary);
  }

  /* Grid */
  .services__grid {
    display: grid;
    grid-template-columns: 1fr;
    gap: var(--space-6);
    margin-bottom: var(--space-10);
  }

  /* Nota inferior */
  .services__note {
    text-align: center;
    font-size: var(--text-sm);
    color: var(--color-text-muted);
  }

  /* Responsive */
  @media (min-width: 768px) {
    .services__grid {
      grid-template-columns: repeat(2, 1fr);
    }
  }

  @media (min-width: 1100px) {
    .services__grid {
      grid-template-columns: repeat(3, 1fr);
      align-items: start;
    }
  }
</style>
