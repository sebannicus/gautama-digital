---
/**
 * CtaFinal.astro
 * CTA final — visual-first, texto mínimo.
 * Stats strip + botones + contacto.
 */

import Button from '../ui/Button.astro';
import { SITE } from '../../content/site';

const whatsappMsg = encodeURIComponent('Hola Seba, quiero solicitar el diagnóstico gratuito para mi negocio. ¿Tienes disponibilidad?');
const whatsappUrl = `https://wa.me/${SITE.whatsapp}?text=${whatsappMsg}`;

const stats = [
  { value: '6+', label: 'proyectos entregados' },
  { value: '30d', label: 'para aparecer en Google' },
  { value: '$0', label: 'en publicidad pagada' },
  { value: '15d', label: 'tiempo de entrega' },
];
---

<section class="cta-final section" id="contacto" aria-label="Contacto final">
  <div class="cta-final__bg" aria-hidden="true">
    <div class="bg-glow bg-glow--gold cta-final__glow--1"></div>
    <div class="bg-glow bg-glow--violet cta-final__glow--2"></div>
  </div>

  <div class="container cta-final__inner" data-scroll-children>

    <!-- Strip de stats -->
    <div class="cta-stats">
      {stats.map(s => (
        <div class="cta-stats__item">
          <span class="cta-stats__val">{s.value}</span>
          <span class="cta-stats__lbl">{s.label}</span>
        </div>
      ))}
    </div>

    <h2 class="cta-final__title">
      ¿Listo para que Google<br />
      <span class="text-gradient-gold">trabaje por tu negocio?</span>
    </h2>

    <!-- Tarjeta visual de diagnóstico -->
    <div class="cta-diag" aria-hidden="true">
      <div class="cta-diag__icon">
        <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round">
          <path d="M21 15a2 2 0 01-2 2H7l-4 4V5a2 2 0 012-2h14a2 2 0 012 2z"/>
        </svg>
      </div>
      <div class="cta-diag__text">
        <strong>Diagnóstico gratuito · 30 min</strong>
        <span>Analizamos tu negocio y te entregamos un plan concreto. Sin costo.</span>
      </div>
      <div class="cta-diag__badge">GRATIS</div>
    </div>

    <!-- Botones -->
    <div class="cta-final__actions">
      <Button href={whatsappUrl} variant="whatsapp" size="lg" external={true} pulse={true}>
        Solicitar diagnóstico gratuito
      </Button>
      <Button href={`mailto:${SITE.email}`} variant="ghost" size="lg">
        Cotizar por correo
      </Button>
    </div>

    <!-- Contacto directo -->
    <div class="cta-final__contact">
      <a href={`mailto:${SITE.email}`} class="cta-final__contact-item">
        <svg aria-hidden="true" width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8">
          <path d="M4 4h16c1.1 0 2 .9 2 2v12c0 1.1-.9 2-2 2H4c-1.1 0-2-.9-2-2V6c0-1.1.9-2 2-2z"/>
          <polyline points="22,6 12,13 2,6"/>
        </svg>
        {SITE.email}
      </a>
      {SITE.social.instagram && (
        <a href={SITE.social.instagram} class="cta-final__contact-item" target="_blank" rel="noopener noreferrer">
          <svg aria-hidden="true" width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8">
            <rect x="2" y="2" width="20" height="20" rx="5"/>
            <circle cx="12" cy="12" r="4"/>
            <circle cx="17.5" cy="6.5" r="1" fill="currentColor" stroke="none"/>
          </svg>
          @gautamadigital
        </a>
      )}
    </div>

    <p class="cta-final__guarantee">
      <svg aria-hidden="true" width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
        <path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"/><polyline points="9 12 11 14 15 10"/>
      </svg>
      Sin contrato · Sin mensualidades · El sitio es tuyo
    </p>
  </div>
</section>

<style>
  .cta-final {
    position: relative;
    overflow: hidden;
  }

  .cta-final__bg { position: absolute; inset: 0; pointer-events: none; }
  .cta-final__glow--1 { width: 700px; height: 700px; top: -200px; right: -200px; opacity: 0.06; }
  .cta-final__glow--2 { width: 500px; height: 500px; bottom: -100px; left: -100px; opacity: 0.05; }

  .cta-final__inner {
    position: relative;
    z-index: var(--z-above);
    text-align: center;
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: var(--space-8);
  }

  /* Stats strip */
  .cta-stats {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: var(--space-4);
    width: 100%;
    max-width: 600px;
  }

  @media (min-width: 640px) {
    .cta-stats {
      grid-template-columns: repeat(4, 1fr);
    }
  }

  .cta-stats__item {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: var(--space-1);
    background: var(--color-bg-surface);
    border: 1px solid var(--color-border);
    border-radius: var(--radius-xl);
    padding: var(--space-5) var(--space-4);
    transition: border-color var(--transition-base), transform var(--transition-slow);
  }

  .cta-stats__item:hover {
    border-color: var(--color-border-hover);
    transform: translateY(-2px);
  }

  .cta-stats__val {
    font-family: var(--font-headline);
    font-size: clamp(var(--text-3xl), 4vw, var(--text-4xl));
    font-weight: var(--weight-extrabold);
    line-height: 1;
    background: linear-gradient(135deg, var(--color-gold), var(--color-gold-light));
    -webkit-background-clip: text;
    -webkit-text-fill-color: transparent;
    background-clip: text;
  }

  .cta-stats__lbl {
    font-family: var(--font-subhead);
    font-size: var(--text-xs);
    color: var(--color-text-muted);
    letter-spacing: var(--tracking-wide);
    text-align: center;
    line-height: var(--leading-snug);
  }

  .cta-final__title {
    font-size: clamp(var(--text-3xl), 5vw, var(--text-6xl));
    max-width: 700px;
  }

  /* Tarjeta de diagnóstico */
  .cta-diag {
    display: flex;
    align-items: center;
    gap: var(--space-4);
    background: var(--color-bg-surface);
    border: 1px solid var(--color-border);
    border-radius: var(--radius-xl);
    padding: var(--space-4) var(--space-6);
    max-width: 480px;
    width: 100%;
    text-align: left;
  }

  .cta-diag__icon {
    width: 44px;
    height: 44px;
    display: flex;
    align-items: center;
    justify-content: center;
    background: linear-gradient(135deg, rgba(4,119,191,0.1), rgba(4,196,217,0.06));
    border: 1px solid var(--color-border);
    border-radius: var(--radius-lg);
    color: var(--color-gold);
    flex-shrink: 0;
  }

  .cta-diag__text {
    flex: 1;
    display: flex;
    flex-direction: column;
    gap: 3px;
  }

  .cta-diag__text strong {
    font-size: var(--text-sm);
    font-weight: var(--weight-bold);
    color: var(--color-text-primary);
  }

  .cta-diag__text span {
    font-size: var(--text-xs);
    color: var(--color-text-secondary);
    line-height: var(--leading-snug);
  }

  .cta-diag__badge {
    font-family: var(--font-subhead);
    font-size: 10px;
    font-weight: var(--weight-extrabold);
    letter-spacing: var(--tracking-widest);
    color: #2ECC71;
    background: rgba(46,204,113,0.1);
    border: 1px solid rgba(46,204,113,0.25);
    border-radius: var(--radius-full);
    padding: 3px var(--space-3);
    flex-shrink: 0;
  }

  .cta-final__actions {
    display: flex;
    flex-wrap: wrap;
    justify-content: center;
    gap: var(--space-4);
  }

  .cta-final__contact {
    display: flex;
    flex-wrap: wrap;
    justify-content: center;
    gap: var(--space-6);
  }

  .cta-final__contact-item {
    display: flex;
    align-items: center;
    gap: var(--space-2);
    font-size: var(--text-sm);
    color: var(--color-text-secondary);
    text-decoration: none;
    transition: color var(--transition-fast);
  }

  .cta-final__contact-item:hover { color: var(--color-gold); }

  .cta-final__guarantee {
    display: flex;
    align-items: center;
    gap: var(--space-2);
    font-size: var(--text-xs);
    color: var(--color-text-muted);
    flex-wrap: wrap;
    justify-content: center;
  }

  .cta-final__guarantee svg { flex-shrink: 0; color: var(--color-gold); }

  @media (max-width: 640px) {
    .cta-final__actions { flex-direction: column; width: 100%; }
    .cta-final__actions :global(.btn) { width: 100%; }
    .cta-diag { flex-wrap: wrap; }
  }
</style>
