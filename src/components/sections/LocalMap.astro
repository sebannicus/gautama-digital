---
/**
 * LocalMap.astro
 * Propósito: Mapa de Google Maps + datos de contacto.
 * Refuerza presencia local (SEO) y facilita que clientes nos encuentren.
 *
 * INSTRUCCIONES PARA ACTIVAR EL MAPA:
 * 1. Ve a Google Maps → busca tu ficha de negocio
 * 2. Clic en "Compartir" → "Incorporar un mapa"
 * 3. Copia la URL que viene dentro del atributo src="..." del iframe
 * 4. Pégala en la constante MAPS_EMBED_URL abajo.
 */

import { SITE } from '../../content/site';
import SectionLabel from '../ui/SectionLabel.astro';

/**
 * ⬇️  REEMPLAZA con tu URL real de Google Maps embed.
 * Ejemplo: https://www.google.com/maps/embed?pb=!1m18!1m12!...
 */
const MAPS_EMBED_URL = '';
const HAS_MAP = MAPS_EMBED_URL.length > 0;
---

<section class="local-map section" id="ubicacion" aria-label="Ubicación y contacto">
  <div class="container">

    <div class="local-map__header gs-fade-up">
      <SectionLabel>Dónde estamos</SectionLabel>
      <h2 class="local-map__title">
        Trabajamos en <span class="text-gradient-gold">La Serena y Coquimbo</span>
      </h2>
      <p class="local-map__sub">
        Atención remota para todo Chile. Reuniones presenciales en la IV Región.
      </p>
    </div>

    <div class="local-map__body">

      <!-- Info de contacto -->
      <div class="local-map__info gs-slide-left">
        <ul class="local-map__contacts">
          <li class="local-map__contact-item">
            <span class="local-map__contact-icon" aria-hidden="true">
              <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                <path d="M22 16.92v3a2 2 0 01-2.18 2 19.79 19.79 0 01-8.63-3.07A19.5 19.5 0 013.8 10.8a19.79 19.79 0 01-3.07-8.67A2 2 0 012.7 0h3a2 2 0 012 1.72c.13 1 .37 1.97.72 2.9a2 2 0 01-.45 2.11L6.91 7.79a16 16 0 006.29 6.29l1.06-1.06a2 2 0 012.11-.45c.93.35 1.9.59 2.9.72A2 2 0 0122 16.92z"/>
              </svg>
            </span>
            <div>
              <span class="local-map__contact-label">Teléfono / WhatsApp</span>
              <a href={`tel:${SITE.phone}`} class="local-map__contact-value">{SITE.phone}</a>
            </div>
          </li>

          <li class="local-map__contact-item">
            <span class="local-map__contact-icon" aria-hidden="true">
              <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                <path d="M4 4h16c1.1 0 2 .9 2 2v12c0 1.1-.9 2-2 2H4c-1.1 0-2-.9-2-2V6c0-1.1.9-2 2-2z"/>
                <polyline points="22,6 12,13 2,6"/>
              </svg>
            </span>
            <div>
              <span class="local-map__contact-label">Correo</span>
              <a href={`mailto:${SITE.email}`} class="local-map__contact-value">{SITE.email}</a>
            </div>
          </li>

          <li class="local-map__contact-item">
            <span class="local-map__contact-icon" aria-hidden="true">
              <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                <path d="M21 10c0 7-9 13-9 13s-9-6-9-13a9 9 0 0118 0z"/>
                <circle cx="12" cy="10" r="3"/>
              </svg>
            </span>
            <div>
              <span class="local-map__contact-label">Zona de atención</span>
              <span class="local-map__contact-value">{SITE.location.city} · La Serena · Chile</span>
            </div>
          </li>
        </ul>

        <!-- Badge horario -->
        <div class="local-map__badge">
          <span class="local-map__badge-dot" aria-hidden="true"></span>
          <span>Respondemos dentro de las 24 horas hábiles</span>
        </div>
      </div>

      <!-- Mapa -->
      <div class="local-map__map-wrapper gs-slide-right">
        {HAS_MAP ? (
          <iframe
            src={MAPS_EMBED_URL}
            class="local-map__iframe"
            width="100%"
            height="100%"
            style="border: 0;"
            allowfullscreen
            loading="lazy"
            referrerpolicy="no-referrer-when-downgrade"
            title={`Mapa de ${SITE.name} en ${SITE.location.city}`}
          />
        ) : (
          <!-- Placeholder mientras no está configurado el mapa -->
          <div class="local-map__placeholder">
            <svg width="48" height="48" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" aria-hidden="true">
              <path d="M21 10c0 7-9 13-9 13s-9-6-9-13a9 9 0 0118 0z"/>
              <circle cx="12" cy="10" r="3"/>
            </svg>
            <p>
              La Serena &amp; Coquimbo<br />
              <span>IV Región, Chile</span>
            </p>
            <a
              href={`https://maps.google.com/?q=La+Serena+Coquimbo+Chile`}
              target="_blank"
              rel="noopener noreferrer"
              class="local-map__placeholder-link"
            >
              Ver en Google Maps →
            </a>
          </div>
        )}
      </div>

    </div>
  </div>
</section>

<script>
  import { initScrollReveal } from '../../utils/animations';
  initScrollReveal();
</script>

<style>
  .local-map {
    background-color: var(--color-bg);
  }

  /* Header */
  .local-map__header {
    text-align: center;
    margin-bottom: var(--space-12);
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: var(--space-4);
  }

  .local-map__title {
    font-size: clamp(var(--text-3xl), 4vw, var(--text-5xl));
    font-weight: var(--weight-extrabold);
  }

  .local-map__sub {
    color: var(--color-text-secondary);
    max-width: 440px;
  }

  /* Body — dos columnas */
  .local-map__body {
    display: grid;
    grid-template-columns: 1fr;
    gap: var(--space-8);
    align-items: stretch;
  }

  @media (min-width: 768px) {
    .local-map__body {
      grid-template-columns: 1fr 1.4fr;
      gap: var(--space-12);
    }
  }

  /* Info de contacto */
  .local-map__info {
    display: flex;
    flex-direction: column;
    gap: var(--space-8);
    justify-content: center;
  }

  .local-map__contacts {
    display: flex;
    flex-direction: column;
    gap: var(--space-6);
  }

  .local-map__contact-item {
    display: flex;
    align-items: flex-start;
    gap: var(--space-4);
  }

  .local-map__contact-icon {
    width: 44px;
    height: 44px;
    background-color: var(--color-bg-surface);
    border: 1px solid var(--color-border);
    border-radius: var(--radius-lg);
    display: flex;
    align-items: center;
    justify-content: center;
    color: var(--color-gold);
    flex-shrink: 0;
    transition: background-color var(--transition-base), border-color var(--transition-base);
  }

  .local-map__contact-item:hover .local-map__contact-icon {
    background-color: var(--color-violet);
    border-color: var(--color-border-hover);
  }

  .local-map__contact-label {
    display: block;
    font-size: var(--text-xs);
    color: var(--color-text-muted);
    letter-spacing: var(--tracking-wide);
    text-transform: uppercase;
    margin-bottom: 2px;
  }

  .local-map__contact-value {
    font-size: var(--text-base);
    font-weight: var(--weight-semibold);
    color: var(--color-text-primary);
    text-decoration: none;
    transition: color var(--transition-fast);
  }

  a.local-map__contact-value:hover {
    color: var(--color-gold-light);
  }

  /* Badge */
  .local-map__badge {
    display: inline-flex;
    align-items: center;
    gap: var(--space-2);
    font-size: var(--text-sm);
    color: var(--color-text-secondary);
    background-color: var(--color-bg-surface);
    border: 1px solid var(--color-border);
    border-radius: var(--radius-full);
    padding: var(--space-2) var(--space-4);
    align-self: flex-start;
  }

  .local-map__badge-dot {
    width: 8px;
    height: 8px;
    background: var(--color-success);
    border-radius: 50%;
    flex-shrink: 0;
    animation: pulse-gold 2.5s ease-in-out infinite;
  }

  /* Mapa iframe */
  .local-map__map-wrapper {
    border-radius: var(--radius-xl);
    overflow: hidden;
    border: 1px solid var(--color-border);
    min-height: 360px;
    background-color: var(--color-bg-surface);
    box-shadow: var(--shadow-card);
  }

  .local-map__iframe {
    display: block;
    width: 100%;
    height: 100%;
    min-height: 360px;
  }

  /* Placeholder (sin URL configurada) */
  .local-map__placeholder {
    width: 100%;
    height: 100%;
    min-height: 360px;
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    gap: var(--space-4);
    color: var(--color-text-muted);
    text-align: center;
    padding: var(--space-8);
  }

  .local-map__placeholder p {
    font-size: var(--text-lg);
    font-weight: var(--weight-semibold);
    color: var(--color-text-secondary);
    line-height: var(--leading-snug);
  }

  .local-map__placeholder p span {
    font-size: var(--text-sm);
    font-weight: var(--weight-regular);
    color: var(--color-text-muted);
  }

  .local-map__placeholder-link {
    font-size: var(--text-sm);
    font-weight: var(--weight-semibold);
    color: var(--color-gold);
    text-decoration: none;
    transition: color var(--transition-fast);
  }

  .local-map__placeholder-link:hover {
    color: var(--color-gold-light);
  }
</style>
