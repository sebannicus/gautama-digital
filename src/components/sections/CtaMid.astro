---
/**
 * CtaMid.astro
 * Propósito: CTA intermedio de alta conversión entre el caso de estudio y el FAQ.
 * Objetivo: capturar al prospecto que ya confía pero aún no ha actuado.
 */

import Button from '../ui/Button.astro';
import { SITE } from '../../content/site';

const whatsappMsg = encodeURIComponent('Hola Seba, quiero cotizar mi sitio web. ¿Cuándo podemos hablar?');
const whatsappUrl = `https://wa.me/${SITE.whatsapp}?text=${whatsappMsg}`;
---

<section class="cta-mid" aria-label="Llamada a la acción">
  <!-- Fondo con glow dorado -->
  <div class="cta-mid__bg" aria-hidden="true">
    <div class="bg-glow bg-glow--gold cta-mid__glow"></div>
  </div>

  <div class="container cta-mid__inner gs-fade-up">
    <div class="cta-mid__content">
      <p class="cta-mid__tag">
        <span class="cta-mid__tag-dot" aria-hidden="true"></span>
        Diagnóstico gratuito · Sin compromiso
      </p>

      <h2 class="cta-mid__title">
        Cuéntale a Seba lo que necesitas.<br />
        <span class="text-gradient-gold">En 30 minutos tienes un plan.</span>
      </h2>

      <p class="cta-mid__sub">
        Una llamada. Sin costo. Sin presión. Solo una conversación honesta sobre
        cómo tu negocio puede aparecer en Google.
      </p>

      <div class="cta-mid__actions">
        <Button href={whatsappUrl} variant="primary" size="lg" external={true} pulse={true}>
          Cotizar por WhatsApp
        </Button>
        <a href={`mailto:${SITE.email}`} class="cta-mid__email-link">
          o escribe a {SITE.email}
        </a>
      </div>
    </div>
  </div>
</section>

<style>
  .cta-mid {
    position: relative;
    padding-block: var(--space-20);
    overflow: hidden;
    background: linear-gradient(
      135deg,
      rgba(191, 189, 242, 0.18) 0%,
      transparent 50%,
      rgba(53, 47, 89, 0.06) 100%
    );
    border-block: 1px solid var(--color-border);
  }

  .cta-mid__bg {
    position: absolute;
    inset: 0;
    pointer-events: none;
  }

  .cta-mid__glow {
    width: 600px;
    height: 600px;
    top: 50%;
    left: 50%;
    transform: translate(-50%, -50%);
    opacity: 0.06;
  }

  .cta-mid__inner {
    position: relative;
    z-index: var(--z-above);
  }

  .cta-mid__content {
    text-align: center;
    max-width: 660px;
    margin-inline: auto;
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: var(--space-5);
  }

  /* Tag */
  .cta-mid__tag {
    display: inline-flex;
    align-items: center;
    gap: var(--space-2);
    font-family: var(--font-subhead);
    font-size: var(--text-xs);
    font-weight: var(--weight-semibold);
    letter-spacing: var(--tracking-widest);
    text-transform: uppercase;
    color: var(--color-text-secondary);
    background: rgba(53, 47, 89, 0.06);
    border: 1px solid var(--color-border);
    border-radius: var(--radius-full);
    padding: var(--space-2) var(--space-4);
  }

  .cta-mid__tag-dot {
    width: 6px;
    height: 6px;
    background: var(--color-gold);
    border-radius: 50%;
    animation: pulse-gold 2s ease-in-out infinite;
    flex-shrink: 0;
  }

  /* Title */
  .cta-mid__title {
    font-size: clamp(var(--text-2xl), 4vw, var(--text-4xl));
    line-height: var(--leading-tight);
  }

  /* Sub */
  .cta-mid__sub {
    font-size: var(--text-base);
    color: var(--color-text-secondary);
    line-height: var(--leading-relaxed);
    max-width: 520px;
  }

  /* Actions */
  .cta-mid__actions {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: var(--space-3);
  }

  .cta-mid__email-link {
    font-size: var(--text-sm);
    color: var(--color-text-muted);
    text-decoration: none;
    transition: color var(--transition-fast);
  }

  .cta-mid__email-link:hover {
    color: var(--color-gold);
  }
</style>
