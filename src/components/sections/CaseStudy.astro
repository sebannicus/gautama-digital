---
/**
 * CaseStudy.astro
 * Propósito: Caso de estudio CheckVital — prueba social detallada.
 * Estrategia: mostrar el "antes y después" + keywords verificadas.
 * Relación: consume CASE_STUDIES[0].
 */

import SectionLabel from '../ui/SectionLabel.astro';
import MetricCard from '../ui/MetricCard.astro';
import Button from '../ui/Button.astro';
import { CASE_STUDIES } from '../../content/caseStudies';
import { SITE } from '../../content/site';

const cs = CASE_STUDIES[0];

const whatsappMsg = encodeURIComponent(`Hola Seba, vi el caso de ${cs.clientName} y me interesa algo similar para mi negocio.`);
const whatsappUrl = `https://wa.me/${SITE.whatsapp}?text=${whatsappMsg}`;
---

<section class="case-study section section--surface" id="caso-checkvital" aria-labelledby="cs-heading">
  <div class="container">
    <div class="case-study__header" data-scroll-children>
      <SectionLabel text="CASO DE ESTUDIO" align="center" />
      <h2 class="case-study__title" id="cs-heading">
        {cs.clientName}: de cero presencia<br />
        <span class="text-gradient-gold">a Top en Google Maps.</span>
      </h2>
      <p class="case-study__meta">
        {cs.industry} · {cs.location} ·
        <a href={`https://${cs.url}`} class="link-gold" target="_blank" rel="noopener noreferrer">
          {cs.url}
        </a>
      </p>
    </div>

    <!-- Challenge / Solution -->
    <div class="case-study__split">
      <div class="case-study__block gs-slide-left">
        <div class="case-study__block-label">El problema</div>
        <p class="case-study__block-text">{cs.challenge}</p>
      </div>
      <div class="case-study__block gs-slide-right">
        <div class="case-study__block-label">La solución</div>
        <p class="case-study__block-text">{cs.solution}</p>
      </div>
    </div>

    <!-- Métricas -->
    <div class="case-study__metrics">
      {cs.metrics.map((metric) => (
        <MetricCard
          value={metric.value}
          label={metric.label}
          source={metric.source}
        />
      ))}
    </div>

    <!-- Keywords -->
    <div class="case-study__keywords gs-fade-in">
      <p class="case-study__keywords-title">Posicionado orgánicamente para:</p>
      <div class="case-study__keywords-list">
        {cs.mapKeywords.map((kw) => (
          <div class="case-study__keyword-item">
            <svg aria-hidden="true" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
              <path d="M12 2C8.13 2 5 5.13 5 9c0 5.25 7 13 7 13s7-7.75 7-13c0-3.87-3.13-7-7-7z"/>
              <circle cx="12" cy="9" r="2.5"/>
            </svg>
            <span>"{kw}"</span>
          </div>
        ))}
      </div>
      <p class="case-study__keywords-note">
        Verificado manualmente en Google Maps — sin pagar un peso en ads.
      </p>
    </div>

    <!-- CTA -->
    <div class="case-study__cta gs-fade-up">
      <p class="case-study__cta-text">¿Tu negocio puede tener los mismos resultados?</p>
      <Button href={whatsappUrl} variant="primary" size="lg" external={true}>
        Quiero resultados como CheckVital
      </Button>
    </div>
  </div>
</section>

<style>
  /* Header */
  .case-study__header {
    text-align: center;
    margin-bottom: var(--space-12);
  }

  .case-study__title {
    font-size: clamp(var(--text-3xl), 4vw, var(--text-5xl));
    margin-bottom: var(--space-3);
  }

  .case-study__meta {
    font-size: var(--text-sm);
    color: var(--color-text-muted);
  }

  /* Split challenge/solution */
  .case-study__split {
    display: grid;
    grid-template-columns: 1fr;
    gap: var(--space-4);
    margin-bottom: var(--space-10);
  }

  .case-study__block {
    background-color: var(--color-bg-overlay);
    border: 1px solid var(--color-border);
    border-radius: var(--radius-lg);
    padding: var(--space-6);
  }

  .case-study__block-label {
    font-family: var(--font-subhead);
    font-size: var(--text-xs);
    font-weight: var(--weight-bold);
    letter-spacing: var(--tracking-widest);
    text-transform: uppercase;
    color: var(--color-gold);
    margin-bottom: var(--space-3);
  }

  .case-study__block-text {
    font-size: var(--text-sm);
    color: var(--color-text-secondary);
    line-height: var(--leading-relaxed);
  }

  /* Métricas */
  .case-study__metrics {
    display: grid;
    grid-template-columns: 1fr;
    gap: var(--space-4);
    margin-bottom: var(--space-8);
  }

  /* Keywords */
  .case-study__keywords {
    background-color: rgba(4, 119, 191, 0.04);
    border: 1px solid var(--color-border);
    border-radius: var(--radius-xl);
    padding: var(--space-6) var(--space-8);
    margin-bottom: var(--space-10);
    text-align: center;
  }

  .case-study__keywords-title {
    font-family: var(--font-subhead);
    font-size: var(--text-sm);
    font-weight: var(--weight-semibold);
    color: var(--color-text-primary);
    margin-bottom: var(--space-4);
  }

  .case-study__keywords-list {
    display: flex;
    flex-wrap: wrap;
    justify-content: center;
    gap: var(--space-4);
    margin-bottom: var(--space-4);
  }

  .case-study__keyword-item {
    display: flex;
    align-items: center;
    gap: var(--space-2);
    font-family: var(--font-subhead);
    font-size: var(--text-sm);
    font-weight: var(--weight-medium);
    color: var(--color-gold);
  }

  .case-study__keyword-item svg {
    flex-shrink: 0;
  }

  .case-study__keywords-note {
    font-size: var(--text-xs);
    color: var(--color-text-muted);
    font-style: italic;
  }

  /* CTA */
  .case-study__cta {
    text-align: center;
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: var(--space-4);
  }

  .case-study__cta-text {
    font-size: var(--text-lg);
    color: var(--color-text-secondary);
    font-weight: var(--weight-medium);
  }

  /* Responsive */
  @media (min-width: 768px) {
    .case-study__split {
      grid-template-columns: 1fr 1fr;
    }

    .case-study__metrics {
      grid-template-columns: repeat(3, 1fr);
    }
  }
</style>
