---
/**
 * CaseStudy.astro → Propuesta de valor
 * Propósito: Comunicar los servicios concretos que entrega Gautama Digital.
 */

import SectionLabel from '../ui/SectionLabel.astro';
import Button from '../ui/Button.astro';
import { SITE } from '../../content/site';

const whatsappMsg = encodeURIComponent('Hola Seba, quiero saber más sobre tus servicios para mi negocio.');
const whatsappUrl = `https://wa.me/${SITE.whatsapp}?text=${whatsappMsg}`;

const servicios = [
  {
    num: '01',
    titulo: 'Diseño web hecho a medida',
    desc: 'Sin plantillas compradas. Cada sitio se construye desde cero con tu identidad y tu cliente ideal. Diseño que comunica profesionalismo antes de que lean una palabra.',
    icon: `<rect x="3" y="3" width="18" height="18" rx="2"/><path d="M3 9h18M9 21V9"/>`,
  },
  {
    num: '02',
    titulo: 'SEO Local + Google Maps',
    desc: 'Posiciono tu negocio en las búsquedas de tu ciudad. Tus clientes te encuentran cuando te necesitan — sin que pagues publicidad mes a mes.',
    icon: `<path d="M12 2C8.13 2 5 5.13 5 9c0 5.25 7 13 7 13s7-7.75 7-13c0-3.87-3.13-7-7-7z"/><circle cx="12" cy="9" r="2.5"/>`,
  },
  {
    num: '03',
    titulo: 'Analíticas desde el día 1',
    desc: 'GA4 + Meta Pixel configurados. Sabes exactamente cuánta gente visita tu sitio, de dónde vienen y qué hacen. Decisiones basadas en datos, no en intuición.',
    icon: `<polyline points="22 12 18 12 15 21 9 3 6 12 2 12"/>`,
  },
  {
    num: '04',
    titulo: 'Agente WhatsApp con IA',
    desc: 'Automatiza la atención de consultas, califica leads y agenda clientes. Tu negocio responde y vende aunque estés ocupado o durmiendo.',
    icon: `<path d="M21 15a2 2 0 01-2 2H7l-4 4V5a2 2 0 012-2h14a2 2 0 012 2z"/>`,
  },
];
---

<section class="value-prop section section--surface" id="propuesta-valor" aria-labelledby="vp-heading">
  <div class="container">

    <div class="vp__header" data-scroll-children>
      <SectionLabel text="LO QUE ENTREGO" align="center" />
      <h2 class="vp__title" id="vp-heading">
        El sistema completo para que<br />
        <span class="text-gradient-gold">tu negocio trabaje solo.</span>
      </h2>
      <p class="vp__sub">
        No es solo diseño. Es la infraestructura digital completa para atraer, convencer y medir clientes — sin depender de publicidad pagada.
      </p>
    </div>

    <!-- 4 pilares de servicio -->
    <div class="vp__grid">
      {servicios.map((s, i) => (
        <article class="vp__card gs-fade-up" style={`animation-delay: ${i * 80}ms`}>
          <div class="vp__card-top">
            <span class="vp__num">{s.num}</span>
            <div class="vp__icon" aria-hidden="true">
              <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round" set:html={s.icon} />
            </div>
          </div>
          <h3 class="vp__card-title">{s.titulo}</h3>
          <p class="vp__card-desc">{s.desc}</p>
        </article>
      ))}
    </div>

    <!-- Strip diferenciadores -->
    <div class="vp__strip gs-fade-in">
      {['Sitio hecho a medida', 'Sin publicidad pagada', 'El sitio es tuyo desde el día 1', 'Resultados medibles', 'Entrega en 2 semanas'].map(item => (
        <div class="vp__strip-item">
          <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" aria-hidden="true">
            <path d="M22 11.08V12a10 10 0 11-5.93-9.14"/><polyline points="22 4 12 14.01 9 11.01"/>
          </svg>
          <span>{item}</span>
        </div>
      ))}
    </div>

    <!-- CTA -->
    <div class="vp__cta gs-fade-up">
      <p class="vp__cta-text">¿Listo para tener un sitio que trabaje para ti?</p>
      <Button href={whatsappUrl} variant="primary" size="lg" external={true}>
        Cotización gratis por WhatsApp
      </Button>
    </div>

  </div>
</section>

<script>
  import { initScrollReveal } from '../../utils/animations';
  initScrollReveal();
</script>

<style>
  .vp__header {
    text-align: center;
    margin-bottom: var(--space-12);
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: var(--space-4);
  }

  .vp__title {
    font-size: clamp(var(--text-3xl), 4vw, var(--text-5xl));
    font-weight: var(--weight-extrabold);
    line-height: var(--leading-tight);
    letter-spacing: var(--tracking-tight);
  }

  .vp__sub {
    font-size: var(--text-base);
    color: var(--color-text-secondary);
    max-width: 520px;
    line-height: var(--leading-relaxed);
  }

  /* Grid de servicios */
  .vp__grid {
    display: grid;
    grid-template-columns: 1fr;
    gap: var(--space-5);
    margin-bottom: var(--space-10);
  }

  @media (min-width: 640px) {
    .vp__grid { grid-template-columns: repeat(2, 1fr); }
  }

  @media (min-width: 1024px) {
    .vp__grid { grid-template-columns: repeat(4, 1fr); }
  }

  /* Card */
  .vp__card {
    background: var(--color-bg);
    border: 1px solid var(--color-border);
    border-radius: var(--radius-xl);
    padding: var(--space-6);
    display: flex;
    flex-direction: column;
    gap: var(--space-4);
    transition: border-color var(--transition-base), box-shadow var(--transition-slow), transform var(--transition-slow);
  }

  .vp__card:hover {
    border-color: var(--color-border-hover);
    box-shadow: var(--shadow-card);
    transform: translateY(-3px);
  }

  .vp__card-top {
    display: flex;
    align-items: center;
    justify-content: space-between;
  }

  .vp__num {
    font-family: var(--font-headline);
    font-size: var(--text-xs);
    font-weight: var(--weight-extrabold);
    color: var(--color-gold);
    letter-spacing: var(--tracking-widest);
    opacity: 0.5;
  }

  .vp__icon {
    width: 40px;
    height: 40px;
    display: flex;
    align-items: center;
    justify-content: center;
    background: linear-gradient(135deg, rgba(4,119,191,0.1), rgba(4,196,217,0.06));
    border: 1px solid var(--color-border);
    border-radius: var(--radius-lg);
    color: var(--color-gold);
    flex-shrink: 0;
  }

  .vp__card-title {
    font-family: var(--font-headline);
    font-size: var(--text-base);
    font-weight: var(--weight-bold);
    color: var(--color-text-primary);
    line-height: var(--leading-snug);
  }

  .vp__card-desc {
    font-size: var(--text-sm);
    color: var(--color-text-secondary);
    line-height: var(--leading-relaxed);
    flex: 1;
  }

  /* Strip */
  .vp__strip {
    display: flex;
    flex-wrap: wrap;
    justify-content: center;
    gap: var(--space-4) var(--space-8);
    padding: var(--space-6) var(--space-8);
    background: var(--color-bg);
    border: 1px solid var(--color-border);
    border-radius: var(--radius-xl);
    margin-bottom: var(--space-10);
  }

  .vp__strip-item {
    display: flex;
    align-items: center;
    gap: var(--space-2);
    font-family: var(--font-subhead);
    font-size: var(--text-sm);
    font-weight: var(--weight-semibold);
    color: var(--color-text-primary);
  }

  .vp__strip-item svg {
    color: var(--color-success);
    flex-shrink: 0;
  }

  /* CTA */
  .vp__cta {
    text-align: center;
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: var(--space-4);
  }

  .vp__cta-text {
    font-size: var(--text-lg);
    color: var(--color-text-secondary);
    font-weight: var(--weight-medium);
  }
</style>
