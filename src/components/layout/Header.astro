---
/**
 * Header.astro
 * Propósito: Barra de navegación fija con logo, nav y CTA.
 * Comportamiento: transparente en top → fondo sólido al hacer scroll.
 * Relación: Consumido por BaseLayout.astro.
 */

import { SITE } from '../../content/site';
import Button from '../ui/Button.astro';

const whatsappMsg = encodeURIComponent('Hola Seba, quiero cotizar un sitio web.');
const whatsappUrl = `https://wa.me/${SITE.whatsapp}?text=${whatsappMsg}`;
---

<header class="header" id="site-header" role="banner">
  <div class="container header__inner">
    <!-- Logo -->
    <a href="/" class="header__logo" aria-label={`${SITE.name} — Inicio`}>
      <span class="header__logo-text">{SITE.name}</span>
      <span class="header__logo-dot" aria-hidden="true">.</span>
    </a>

    <!-- Nav desktop -->
    <nav class="header__nav" aria-label="Navegación principal">
      <ul class="header__nav-list">
        {SITE.nav.map((item) => (
          <li>
            <a href={item.href} class="header__nav-link">{item.label}</a>
          </li>
        ))}
      </ul>
    </nav>

    <!-- CTA desktop -->
    <div class="header__cta">
      <Button href={whatsappUrl} variant="primary" size="sm" external={true}>
        Cotiza gratis
      </Button>
    </div>

    <!-- Hamburger mobile -->
    <button
      class="header__hamburger"
      id="mobile-menu-toggle"
      aria-label="Abrir menú"
      aria-expanded="false"
      aria-controls="mobile-menu"
    >
      <span class="header__hamburger-line"></span>
      <span class="header__hamburger-line"></span>
      <span class="header__hamburger-line"></span>
    </button>
  </div>

  <!-- Menú mobile -->
  <div class="header__mobile" id="mobile-menu" aria-hidden="true">
    <nav aria-label="Menú móvil">
      <ul class="header__mobile-list">
        {SITE.nav.map((item) => (
          <li>
            <a href={item.href} class="header__mobile-link">{item.label}</a>
          </li>
        ))}
      </ul>
    </nav>
    <div class="header__mobile-cta">
      <Button href={whatsappUrl} variant="whatsapp" size="md" external={true}>
        Escribirle a Seba por WhatsApp
      </Button>
    </div>
  </div>
</header>

<script>
  // Scroll → header sólido
  const header = document.getElementById('site-header');
  if (header) {
    const onScroll = () => {
      header.classList.toggle('header--scrolled', window.scrollY > 60);
    };
    window.addEventListener('scroll', onScroll, { passive: true });
    onScroll();
  }

  // Menú mobile toggle
  const toggle = document.getElementById('mobile-menu-toggle');
  const menu = document.getElementById('mobile-menu');

  toggle?.addEventListener('click', () => {
    const isOpen = toggle.getAttribute('aria-expanded') === 'true';
    toggle.setAttribute('aria-expanded', String(!isOpen));
    menu?.setAttribute('aria-hidden', String(isOpen));
    toggle.classList.toggle('header__hamburger--open', !isOpen);
    menu?.classList.toggle('header__mobile--open', !isOpen);
    document.body.classList.toggle('menu-open', !isOpen);
  });

  // Cierra el menú al hacer click en un link
  menu?.querySelectorAll('a').forEach((link) => {
    link.addEventListener('click', () => {
      toggle?.setAttribute('aria-expanded', 'false');
      menu.setAttribute('aria-hidden', 'true');
      toggle?.classList.remove('header__hamburger--open');
      menu.classList.remove('header__mobile--open');
      document.body.classList.remove('menu-open');
    });
  });
</script>

<style>
  .header {
    position: fixed;
    top: 0;
    left: 0;
    right: 0;
    z-index: var(--z-header);
    padding-block: var(--space-4);
    transition: background-color var(--transition-base), backdrop-filter var(--transition-base), padding var(--transition-base);
  }

  .header--scrolled {
    background-color: rgba(240, 248, 252, 0.92);
    backdrop-filter: blur(16px);
    -webkit-backdrop-filter: blur(16px);
    padding-block: var(--space-3);
    border-bottom: 1px solid var(--color-border);
    box-shadow: 0 2px 20px rgba(4, 119, 191, 0.06);
  }

  .header__inner {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: var(--space-6);
  }

  /* Logo */
  .header__logo {
    display: flex;
    align-items: baseline;
    gap: 2px;
    text-decoration: none;
    flex-shrink: 0;
  }

  .header__logo-text {
    font-family: var(--font-headline);
    font-size: var(--text-lg);
    font-weight: var(--weight-bold);
    color: var(--color-text-primary);
    letter-spacing: var(--tracking-tight);
    transition: color var(--transition-fast);
  }

  .header__logo-dot {
    font-family: var(--font-headline);
    font-size: var(--text-2xl);
    font-weight: var(--weight-bold);
    color: var(--color-gold);
    line-height: 1;
  }

  .header__logo:hover .header__logo-text {
    color: var(--color-gold);
  }

  /* Nav desktop */
  .header__nav {
    display: none;
  }

  .header__nav-list {
    display: flex;
    align-items: center;
    gap: var(--space-8);
  }

  .header__nav-link {
    font-family: var(--font-subhead);
    font-size: var(--text-sm);
    font-weight: var(--weight-medium);
    color: var(--color-text-secondary);
    letter-spacing: var(--tracking-wide);
    text-transform: uppercase;
    text-decoration: none;
    transition: color var(--transition-fast);
    position: relative;
  }

  .header__nav-link::after {
    content: '';
    position: absolute;
    bottom: -4px;
    left: 0;
    width: 0;
    height: 1px;
    background: var(--color-gold);
    transition: width var(--transition-base);
  }

  .header__nav-link:hover {
    color: var(--color-gold);
  }

  .header__nav-link:hover::after {
    width: 100%;
  }

  /* CTA desktop */
  .header__cta {
    display: none;
  }

  /* Hamburger */
  .header__hamburger {
    display: flex;
    flex-direction: column;
    justify-content: center;
    gap: 5px;
    width: 32px;
    height: 32px;
    background: transparent;
    border: none;
    cursor: pointer;
    padding: 0;
  }

  .header__hamburger-line {
    display: block;
    width: 100%;
    height: 1.5px;
    background-color: var(--color-text-primary);
    border-radius: var(--radius-full);
    transition: transform var(--transition-base), opacity var(--transition-base);
  }

  .header__hamburger--open .header__hamburger-line:nth-child(1) {
    transform: translateY(6.5px) rotate(45deg);
  }

  .header__hamburger--open .header__hamburger-line:nth-child(2) {
    opacity: 0;
  }

  .header__hamburger--open .header__hamburger-line:nth-child(3) {
    transform: translateY(-6.5px) rotate(-45deg);
  }

  /* Menú mobile */
  .header__mobile {
    display: none;
    flex-direction: column;
    gap: var(--space-6);
    padding: var(--space-6);
    background-color: var(--color-bg-surface);
    border-top: 1px solid var(--color-border);
    margin-top: var(--space-4);
  }

  .header__mobile--open {
    display: flex;
  }

  .header__mobile-list {
    display: flex;
    flex-direction: column;
    gap: var(--space-4);
  }

  .header__mobile-link {
    font-family: var(--font-subhead);
    font-size: var(--text-base);
    font-weight: var(--weight-medium);
    color: var(--color-text-secondary);
    text-decoration: none;
    display: block;
    padding-block: var(--space-2);
    border-bottom: 1px solid var(--color-border);
    transition: color var(--transition-fast);
  }

  .header__mobile-link:hover {
    color: var(--color-gold);
  }

  .header__mobile-cta :global(.btn) {
    width: 100%;
  }

  /* Bloquea scroll cuando menú está abierto */
  :global(body.menu-open) {
    overflow: hidden;
  }

  /* Desktop */
  @media (min-width: 768px) {
    .header__nav {
      display: flex;
    }

    .header__cta {
      display: block;
    }

    .header__hamburger {
      display: none;
    }
  }
</style>
