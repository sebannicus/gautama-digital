---
/**
 * Footer.astro
 * Propósito: Pie de página con links, contacto y copyright.
 * Relación: Consumido por BaseLayout.astro.
 */

import { SITE } from '../../content/site';

const year = new Date().getFullYear();
const whatsappMsg = encodeURIComponent('Hola Seba, quiero cotizar un sitio web.');
const whatsappUrl = `https://wa.me/${SITE.whatsapp}?text=${whatsappMsg}`;
---

<footer class="footer" role="contentinfo">
  <div class="gradient-divider" aria-hidden="true"></div>

  <div class="container footer__inner">
    <!-- Columna: Brand -->
    <div class="footer__brand">
      <a href="/" class="footer__logo" aria-label={`${SITE.name} — Inicio`}>
        <span class="footer__logo-text">{SITE.name}</span>
        <span class="footer__logo-dot" aria-hidden="true">.</span>
      </a>
      <p class="footer__tagline">{SITE.tagline}</p>
      <p class="footer__desc">
        Diseño web, páginas web profesionales y SEO local para negocios en La Serena y Coquimbo.
        Aparecer en Google sin pagar publicidad es posible — te mostramos cómo.
      </p>
      <p class="footer__location">
        <svg aria-hidden="true" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8">
          <path d="M12 2C8.13 2 5 5.13 5 9c0 5.25 7 13 7 13s7-7.75 7-13c0-3.87-3.13-7-7-7z"/>
          <circle cx="12" cy="9" r="2.5"/>
        </svg>
        {SITE.location.city}, {SITE.location.region}
      </p>
    </div>

    <!-- Columna: Servicios -->
    <div class="footer__col">
      <h3 class="footer__col-title">Servicios</h3>
      <ul class="footer__col-list">
        <li><a href="#servicios" class="footer__link">Diseño web La Serena</a></li>
        <li><a href="#servicios" class="footer__link">Páginas web profesionales</a></li>
        <li><a href="#servicios" class="footer__link">SEO local La Serena</a></li>
        <li><a href="#servicios" class="footer__link">Google My Business</a></li>
        <li><a href="#servicios" class="footer__link">Marketing digital</a></li>
        <li><a href="#servicios" class="footer__link">Seguimiento mensual</a></li>
      </ul>
    </div>

    <!-- Columna: Contacto -->
    <div class="footer__col">
      <h3 class="footer__col-title">Contacto</h3>
      <ul class="footer__col-list">
        <li>
          <a href={whatsappUrl} class="footer__link" target="_blank" rel="noopener noreferrer">
            WhatsApp
          </a>
        </li>
        <li>
          <a href={`mailto:${SITE.email}`} class="footer__link">{SITE.email}</a>
        </li>
        {SITE.social.instagram && (
          <li>
            <a href={SITE.social.instagram} class="footer__link" target="_blank" rel="noopener noreferrer">
              Instagram
            </a>
          </li>
        )}
      </ul>
    </div>
  </div>

  <!-- Bottom bar -->
  <div class="footer__bottom">
    <div class="container footer__bottom-inner">
      <p class="footer__copy">
        © {year} {SITE.name} — {SITE.founder.name}. Todos los derechos reservados.
      </p>
      <p class="footer__made">
        Hecho con ❤️ en {SITE.location.city}
      </p>
    </div>
  </div>
</footer>

<style>
  .footer {
    background-color: var(--color-bg-surface);
    margin-top: auto;
  }

  .footer__inner {
    display: grid;
    grid-template-columns: 1fr;
    gap: var(--space-10);
    padding-block: var(--space-16);
  }

  /* Brand */
  .footer__logo {
    display: inline-flex;
    align-items: baseline;
    gap: 2px;
    margin-bottom: var(--space-3);
    text-decoration: none;
  }

  .footer__logo-text {
    font-family: var(--font-headline);
    font-size: var(--text-xl);
    font-weight: var(--weight-bold);
    color: var(--color-text-primary);
    letter-spacing: var(--tracking-tight);
  }

  .footer__logo-dot {
    font-family: var(--font-headline);
    font-size: var(--text-2xl);
    font-weight: var(--weight-bold);
    color: var(--color-gold);
    line-height: 1;
  }

  .footer__tagline {
    font-size: var(--text-sm);
    color: var(--color-text-secondary);
    line-height: var(--leading-relaxed);
    margin-bottom: var(--space-2);
    max-width: 280px;
  }

  .footer__desc {
    font-size: var(--text-xs);
    color: var(--color-text-muted);
    line-height: var(--leading-relaxed);
    margin-bottom: var(--space-3);
    max-width: 300px;
  }

  .footer__location {
    display: flex;
    align-items: center;
    gap: var(--space-2);
    font-size: var(--text-xs);
    color: var(--color-text-muted);
  }

  /* Columnas */
  .footer__col-title {
    font-family: var(--font-subhead);
    font-size: var(--text-xs);
    font-weight: var(--weight-semibold);
    letter-spacing: var(--tracking-widest);
    text-transform: uppercase;
    color: var(--color-gold);
    margin-bottom: var(--space-4);
  }

  .footer__col-list {
    display: flex;
    flex-direction: column;
    gap: var(--space-3);
  }

  .footer__link {
    font-size: var(--text-sm);
    color: var(--color-text-secondary);
    text-decoration: none;
    transition: color var(--transition-fast);
  }

  .footer__link:hover {
    color: var(--color-gold);
  }

  /* Bottom bar */
  .footer__bottom {
    border-top: 1px solid var(--color-border);
    padding-block: var(--space-6);
  }

  .footer__bottom-inner {
    display: flex;
    flex-direction: column;
    gap: var(--space-2);
    align-items: center;
    text-align: center;
  }

  .footer__copy,
  .footer__made {
    font-size: var(--text-xs);
    color: var(--color-text-muted);
  }

  /* Responsive */
  @media (min-width: 640px) {
    .footer__inner {
      grid-template-columns: 1fr 1fr;
    }

    .footer__brand {
      grid-column: 1 / -1;
    }
  }

  @media (min-width: 1024px) {
    .footer__inner {
      grid-template-columns: 2fr 1fr 1fr;
    }

    .footer__brand {
      grid-column: auto;
    }

    .footer__bottom-inner {
      flex-direction: row;
      justify-content: space-between;
      text-align: left;
    }
  }
</style>
