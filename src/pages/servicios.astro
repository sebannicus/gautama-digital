---
/**
 * servicios.astro
 * Propósito: Página dedicada a los paquetes y precios de Gautama Digital.
 * Separada del index para mantener el home limpio y mejorar el SEO de servicios.
 */

import BaseLayout from '../layouts/BaseLayout.astro';
import Services from '../components/sections/Services.astro';
import CtaFinal from '../components/sections/CtaFinal.astro';
import { SITE } from '../content/site';

const title = `Servicios y Precios — Diseño Web La Serena y Coquimbo | ${SITE.name}`;
const description =
  'Paquetes de diseño web en La Serena y Coquimbo desde $280.000. Landing profesional, analíticas completas, tienda online y agente WhatsApp IA. Diagnóstico gratuito sin compromiso.';
const canonicalUrl = `${SITE.url}/servicios`;
---

<BaseLayout title={title} description={description} canonicalUrl={canonicalUrl}>

  <!-- Hero de página -->
  <section class="services-hero section">
    <div class="container">
      <div class="services-hero__inner" data-scroll-children>
        <p class="services-hero__label">PRECIOS Y PAQUETES</p>
        <h1 class="services-hero__title">
          Transparencia total.<br />
          <span class="text-gradient-gold">Pagas por lo que necesitas.</span>
        </h1>
        <p class="services-hero__sub">
          Sin letra chica, sin cobros sorpresa. El diagnóstico inicial siempre es gratuito —
          en 30 minutos te digo exactamente qué necesita tu negocio antes de cobrar un solo peso.
        </p>
        <div class="services-hero__badges">
          <span class="services-hero__badge">
            <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true">
              <path d="M22 11.08V12a10 10 0 11-5.93-9.14"/>
              <polyline points="22 4 12 14.01 9 11.01"/>
            </svg>
            Diagnóstico gratuito
          </span>
          <span class="services-hero__badge">
            <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true">
              <path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"/>
            </svg>
            Pago en 2 cuotas
          </span>
          <span class="services-hero__badge">
            <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true">
              <circle cx="12" cy="12" r="10"/>
              <polyline points="12 6 12 12 16 14"/>
            </svg>
            Entrega en 7–14 días
          </span>
        </div>
      </div>
    </div>
  </section>

  <Services />
  <CtaFinal />

</BaseLayout>

<style>
  .services-hero {
    background-color: var(--color-bg);
    padding-top: calc(var(--space-20) + 80px);
    padding-bottom: 0;
  }

  .services-hero__inner {
    text-align: center;
    max-width: 640px;
    margin-inline: auto;
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: var(--space-5);
  }

  .services-hero__label {
    font-family: var(--font-subhead);
    font-size: var(--text-xs);
    font-weight: var(--weight-bold);
    letter-spacing: var(--tracking-widest);
    text-transform: uppercase;
    color: var(--color-gold);
  }

  .services-hero__title {
    font-size: clamp(var(--text-3xl), 5vw, var(--text-6xl));
    font-weight: var(--weight-extrabold);
    line-height: var(--leading-tight);
  }

  .services-hero__sub {
    font-size: var(--text-base);
    color: var(--color-text-secondary);
    line-height: var(--leading-relaxed);
    max-width: 520px;
  }

  .services-hero__badges {
    display: flex;
    flex-wrap: wrap;
    justify-content: center;
    gap: var(--space-3);
  }

  .services-hero__badge {
    display: inline-flex;
    align-items: center;
    gap: var(--space-2);
    font-family: var(--font-subhead);
    font-size: var(--text-xs);
    font-weight: var(--weight-medium);
    color: var(--color-text-secondary);
    background-color: var(--color-bg-surface);
    border: 1px solid var(--color-border);
    border-radius: var(--radius-full);
    padding: var(--space-2) var(--space-4);
  }

  .services-hero__badge svg {
    color: var(--color-gold);
    flex-shrink: 0;
  }
</style>
