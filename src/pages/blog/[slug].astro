---
/**
 * blog/[slug].astro
 * Propósito: Página individual de artículo del blog.
 * Arquitectura: getStaticPaths genera una ruta por cada post en BLOG_POSTS.
 * SEO: Article schema JSON-LD + meta específicas por post.
 * Relación: consume BLOG_POSTS de content/blog.ts.
 */

import BaseLayout from '../../layouts/BaseLayout.astro';
import { BLOG_POSTS, type BlogPost, type ContentBlock } from '../../content/blog';
import { SITE } from '../../content/site';

export function getStaticPaths() {
  return BLOG_POSTS.map((post) => ({
    params: { slug: post.slug },
    props: { post },
  }));
}

interface Props {
  post: BlogPost;
}

const { post } = Astro.props;

function formatDateLong(iso: string): string {
  const [year, month, day] = iso.split('-').map(Number);
  const months = [
    'enero', 'febrero', 'marzo', 'abril', 'mayo', 'junio',
    'julio', 'agosto', 'septiembre', 'octubre', 'noviembre', 'diciembre',
  ];
  return `${day} de ${months[month - 1]} de ${year}`;
}

const canonicalUrl = `${SITE.url}/blog/${post.slug}`;

const articleSchema = {
  '@context': 'https://schema.org',
  '@type': 'Article',
  headline: post.title,
  description: post.excerpt,
  image: `${SITE.url}/images/og-image.jpg`,
  datePublished: post.publishedAt,
  dateModified: post.publishedAt,
  author: {
    '@type': 'Person',
    name: SITE.founder.name,
    url: SITE.url,
  },
  publisher: {
    '@type': 'Organization',
    name: SITE.name,
    url: SITE.url,
    logo: {
      '@type': 'ImageObject',
      url: `${SITE.url}/favicon.svg`,
    },
  },
  mainEntityOfPage: canonicalUrl,
};

const otherPosts = BLOG_POSTS.filter((p) => p.slug !== post.slug).slice(0, 2);
---

<BaseLayout
  title={`${post.title} | ${SITE.name}`}
  description={post.excerpt}
  canonicalUrl={canonicalUrl}
>
  <script type="application/ld+json" set:html={JSON.stringify(articleSchema)} slot="head" />

  <!-- Hero del artículo -->
  <header class="post-hero" style={`--from: ${post.gradientFrom}; --to: ${post.gradientTo};`}>
    <div class="post-hero__overlay" aria-hidden="true"></div>
    <div class="container post-hero__inner">
      <a href="/#blog" class="post-hero__back">
        <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true">
          <path d="M19 12H5M12 19l-7-7 7-7"/>
        </svg>
        Volver al blog
      </a>

      <div class="post-hero__category" style={`background: ${post.categoryColor}22; color: ${post.categoryColor}; border-color: ${post.categoryColor}55;`}>
        {post.category}
      </div>

      <h1 class="post-hero__title">{post.title}</h1>

      <div class="post-hero__meta">
        <span class="post-hero__author">Por {SITE.founder.name}</span>
        <span class="post-hero__sep" aria-hidden="true">·</span>
        <time datetime={post.publishedAt} class="post-hero__date">
          {formatDateLong(post.publishedAt)}
        </time>
        <span class="post-hero__sep" aria-hidden="true">·</span>
        <span class="post-hero__read">{post.readTime} min de lectura</span>
      </div>
    </div>
  </header>

  <!-- Cuerpo del artículo -->
  <div class="post-layout section">
    <div class="container post-layout__inner">

      <article class="post-body" aria-label={post.title}>
        <p class="post-body__lead">{post.excerpt}</p>

        {post.content.map((block: ContentBlock) => {
          if (block.type === 'h2') {
            return <h2 class="post-body__h2">{block.text}</h2>;
          }
          if (block.type === 'h3') {
            return <h3 class="post-body__h3">{block.text}</h3>;
          }
          if (block.type === 'p') {
            return <p class="post-body__p">{block.text}</p>;
          }
          if (block.type === 'ul') {
            return (
              <ul class="post-body__ul">
                {block.items.map((item: string) => (
                  <li class="post-body__li">{item}</li>
                ))}
              </ul>
            );
          }
          if (block.type === 'highlight') {
            return (
              <blockquote class="post-body__highlight" style={`border-color: ${post.gradientFrom};`}>
                {block.text}
              </blockquote>
            );
          }
          return null;
        })}
      </article>

      <!-- Sidebar -->
      <aside class="post-sidebar">
        <!-- CTA de contacto -->
        <div class="post-cta">
          <p class="post-cta__label">¿Listo para dar el siguiente paso?</p>
          <p class="post-cta__text">
            Cuéntanos sobre tu negocio y te damos un diagnóstico digital gratuito.
          </p>
          <a
            href={`https://wa.me/${SITE.whatsapp}?text=${encodeURIComponent(`Hola, leí el artículo "${post.title}" y quisiera conversar`)}`}
            class="post-cta__btn"
            target="_blank"
            rel="noopener noreferrer"
          >
            <svg width="18" height="18" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
              <path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413z"/>
            </svg>
            Hablar con Sebastián
          </a>
        </div>

        <!-- Otros artículos -->
        {otherPosts.length > 0 && (
          <div class="post-related">
            <p class="post-related__heading">Otros artículos</p>
            <div class="post-related__list">
              {otherPosts.map((p) => (
                <a href={`/blog/${p.slug}`} class="post-related__item">
                  <span class="post-related__cat" style={`color: ${p.categoryColor};`}>{p.category}</span>
                  <span class="post-related__title">{p.title}</span>
                </a>
              ))}
            </div>
          </div>
        )}
      </aside>

    </div>
  </div>
</BaseLayout>

<style>
  /* ── Hero ── */
  .post-hero {
    position: relative;
    background: linear-gradient(135deg, var(--from), var(--to));
    padding: var(--space-16) 0 var(--space-12);
    overflow: hidden;
  }

  .post-hero__overlay {
    position: absolute;
    inset: 0;
    background: linear-gradient(
      to bottom,
      rgba(240, 248, 252, 0.10) 0%,
      rgba(240, 248, 252, 0.55) 100%
    );
    pointer-events: none;
  }

  .post-hero__inner {
    position: relative;
    display: flex;
    flex-direction: column;
    gap: var(--space-4);
  }

  .post-hero__back {
    display: inline-flex;
    align-items: center;
    gap: var(--space-2);
    font-family: var(--font-subhead);
    font-size: var(--text-xs);
    font-weight: var(--weight-semibold);
    color: rgba(255, 255, 255, 0.8);
    text-decoration: none;
    letter-spacing: var(--tracking-wide);
    transition: color var(--transition-fast), gap var(--transition-fast);
    width: fit-content;
  }

  .post-hero__back:hover {
    color: #fff;
    gap: var(--space-3);
  }

  .post-hero__category {
    display: inline-block;
    font-family: var(--font-subhead);
    font-size: 10px;
    font-weight: var(--weight-semibold);
    letter-spacing: var(--tracking-widest);
    text-transform: uppercase;
    border: 1px solid;
    border-radius: var(--radius-full);
    padding: 3px var(--space-3);
    backdrop-filter: blur(4px);
    width: fit-content;
  }

  .post-hero__title {
    font-family: var(--font-headline);
    font-size: clamp(var(--text-2xl), 4vw, var(--text-5xl));
    font-weight: var(--weight-extrabold);
    color: #fff;
    line-height: var(--leading-tight);
    max-width: 740px;
    text-shadow: 0 2px 16px rgba(0,0,0,0.18);
  }

  .post-hero__meta {
    display: flex;
    flex-wrap: wrap;
    align-items: center;
    gap: var(--space-2);
    font-size: var(--text-xs);
    color: rgba(255, 255, 255, 0.75);
    font-family: var(--font-subhead);
    letter-spacing: var(--tracking-wide);
  }

  .post-hero__sep {
    opacity: 0.5;
  }

  /* ── Layout cuerpo ── */
  .post-layout {
    background-color: var(--color-bg);
  }

  .post-layout__inner {
    display: grid;
    grid-template-columns: 1fr;
    gap: var(--space-10);
    align-items: start;
  }

  @media (min-width: 900px) {
    .post-layout__inner {
      grid-template-columns: 1fr 300px;
      gap: var(--space-16);
    }
  }

  /* ── Cuerpo del artículo ── */
  .post-body__lead {
    font-size: var(--text-lg);
    color: var(--color-text-secondary);
    line-height: var(--leading-relaxed);
    font-weight: var(--weight-medium);
    border-left: 3px solid var(--color-gold);
    padding-left: var(--space-5);
    margin-bottom: var(--space-8);
  }

  .post-body__h2 {
    font-family: var(--font-headline);
    font-size: clamp(var(--text-xl), 2.5vw, var(--text-3xl));
    font-weight: var(--weight-bold);
    color: var(--color-text-primary);
    line-height: var(--leading-snug);
    margin-top: var(--space-10);
    margin-bottom: var(--space-4);
  }

  .post-body__h3 {
    font-family: var(--font-headline);
    font-size: var(--text-lg);
    font-weight: var(--weight-semibold);
    color: var(--color-text-primary);
    margin-top: var(--space-6);
    margin-bottom: var(--space-3);
  }

  .post-body__p {
    font-size: var(--text-base);
    color: var(--color-text-secondary);
    line-height: var(--leading-relaxed);
    margin-bottom: var(--space-5);
  }

  .post-body__ul {
    list-style: none;
    padding: 0;
    margin: 0 0 var(--space-6);
    display: flex;
    flex-direction: column;
    gap: var(--space-3);
  }

  .post-body__li {
    font-size: var(--text-base);
    color: var(--color-text-secondary);
    line-height: var(--leading-relaxed);
    padding-left: var(--space-6);
    position: relative;
  }

  .post-body__li::before {
    content: '';
    position: absolute;
    left: 0;
    top: 0.6em;
    width: 6px;
    height: 6px;
    border-radius: 50%;
    background-color: var(--color-gold);
    flex-shrink: 0;
  }

  .post-body__highlight {
    border-left: 4px solid;
    padding: var(--space-5) var(--space-6);
    background-color: var(--color-bg-surface);
    border-radius: 0 var(--radius-md) var(--radius-md) 0;
    font-family: var(--font-headline);
    font-size: var(--text-lg);
    font-weight: var(--weight-semibold);
    color: var(--color-text-primary);
    line-height: var(--leading-snug);
    margin: var(--space-8) 0;
  }

  /* ── Sidebar ── */
  .post-sidebar {
    display: flex;
    flex-direction: column;
    gap: var(--space-6);
  }

  /* CTA sidebar */
  .post-cta {
    background-color: var(--color-bg-surface);
    border: 1px solid var(--color-border);
    border-radius: var(--radius-xl);
    padding: var(--space-6);
    display: flex;
    flex-direction: column;
    gap: var(--space-3);
  }

  .post-cta__label {
    font-family: var(--font-subhead);
    font-size: var(--text-xs);
    font-weight: var(--weight-semibold);
    letter-spacing: var(--tracking-widest);
    text-transform: uppercase;
    color: var(--color-gold);
  }

  .post-cta__text {
    font-size: var(--text-sm);
    color: var(--color-text-secondary);
    line-height: var(--leading-relaxed);
  }

  .post-cta__btn {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    gap: var(--space-2);
    background-color: #25D366;
    color: #fff;
    font-family: var(--font-subhead);
    font-size: var(--text-sm);
    font-weight: var(--weight-semibold);
    text-decoration: none;
    padding: var(--space-3) var(--space-5);
    border-radius: var(--radius-lg);
    transition: background-color var(--transition-fast), transform var(--transition-fast);
    margin-top: var(--space-2);
  }

  .post-cta__btn:hover {
    background-color: #20BD5C;
    transform: translateY(-1px);
  }

  /* Artículos relacionados */
  .post-related {
    background-color: var(--color-bg-surface);
    border: 1px solid var(--color-border);
    border-radius: var(--radius-xl);
    padding: var(--space-5);
    display: flex;
    flex-direction: column;
    gap: var(--space-4);
  }

  .post-related__heading {
    font-family: var(--font-subhead);
    font-size: var(--text-xs);
    font-weight: var(--weight-semibold);
    letter-spacing: var(--tracking-widest);
    text-transform: uppercase;
    color: var(--color-text-muted);
  }

  .post-related__list {
    display: flex;
    flex-direction: column;
    gap: var(--space-3);
  }

  .post-related__item {
    display: flex;
    flex-direction: column;
    gap: 3px;
    text-decoration: none;
    padding: var(--space-3);
    border: 1px solid var(--color-border);
    border-radius: var(--radius-lg);
    transition: border-color var(--transition-base), background-color var(--transition-base);
  }

  .post-related__item:hover {
    border-color: var(--color-border-hover);
    background-color: var(--color-bg);
  }

  .post-related__cat {
    font-family: var(--font-subhead);
    font-size: 10px;
    font-weight: var(--weight-semibold);
    letter-spacing: var(--tracking-wide);
    text-transform: uppercase;
  }

  .post-related__title {
    font-size: var(--text-sm);
    font-weight: var(--weight-semibold);
    color: var(--color-text-primary);
    line-height: var(--leading-snug);
  }
</style>
