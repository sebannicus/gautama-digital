---
import BaseLayout from '../../layouts/BaseLayout.astro';
import SectionLabel from '../../components/ui/SectionLabel.astro';
import { BLOG_POSTS } from '../../content/blog';
import { SITE } from '../../content/site';

const categories = [...new Set(BLOG_POSTS.map((p) => p.category))];
---

<BaseLayout
  title={`Blog — Diseño Web, SEO y Marketing Digital | ${SITE.name}`}
  description="Artículos prácticos sobre diseño web, SEO local, analíticas y automatización IA para negocios en Chile. Sin tecnicismos — solo lo que funciona."
  canonicalUrl={`${SITE.url}/blog`}
>

  <!-- Hero -->
  <section class="blog-hero">
    <div class="blog-hero__bg" aria-hidden="true"></div>
    <div class="container blog-hero__inner">
      <SectionLabel text="BLOG GAUTAMA DIGITAL" align="center" />
      <h1 class="blog-hero__title">
        Todo lo que necesitas saber<br />
        <span class="text-gradient-gold">para crecer digitalmente.</span>
      </h1>
      <p class="blog-hero__sub">
        Artículos sobre diseño web, SEO local, analíticas e inteligencia artificial — escritos para dueños de negocios en Chile, sin tecnicismos.
      </p>
      <div class="blog-hero__count">
        <span class="blog-hero__count-val">{BLOG_POSTS.length}</span>
        <span class="blog-hero__count-lbl">artículos publicados</span>
      </div>
    </div>
  </section>

  <!-- Categorías filtro -->
  <div class="blog-filter">
    <div class="container">
      <div class="blog-filter__pills" role="list">
        <button class="blog-filter__pill blog-filter__pill--active" data-cat="all" role="listitem">
          Todos
        </button>
        {categories.map((cat) => (
          <button class="blog-filter__pill" data-cat={cat} role="listitem">
            {cat}
          </button>
        ))}
      </div>
    </div>
  </div>

  <!-- Grid de artículos -->
  <section class="section blog-grid-section">
    <div class="container">
      <div class="blog-grid" id="blog-grid">
        {BLOG_POSTS.map((post) => (
          <article
            class="blog-card"
            data-cat={post.category}
          >
            <!-- Tira de color -->
            <div
              class="blog-card__bar"
              style={`background: linear-gradient(90deg, ${post.gradientFrom}, ${post.gradientTo});`}
              aria-hidden="true"
            ></div>

            <div class="blog-card__body">
              <div class="blog-card__top">
                <span
                  class="blog-card__cat"
                  style={`color: ${post.categoryColor}; background: ${post.categoryColor}18; border-color: ${post.categoryColor}33;`}
                >
                  {post.category}
                </span>
                <span class="blog-card__time">{post.readTime} min</span>
              </div>

              <h2 class="blog-card__title">
                <a href={`/blog/${post.slug}`} class="blog-card__link">
                  {post.title}
                </a>
              </h2>

              <p class="blog-card__excerpt">{post.excerpt}</p>

              <div class="blog-card__footer">
                <time class="blog-card__date" datetime={post.publishedAt}>
                  {new Date(post.publishedAt + 'T12:00:00').toLocaleDateString('es-CL', {
                    day: 'numeric',
                    month: 'short',
                    year: 'numeric',
                  })}
                </time>
                <a href={`/blog/${post.slug}`} class="blog-card__cta" aria-label={`Leer: ${post.title}`}>
                  Leer →
                </a>
              </div>
            </div>
          </article>
        ))}
      </div>
    </div>
  </section>

</BaseLayout>

<script>
  const pills = document.querySelectorAll<HTMLButtonElement>('.blog-filter__pill');
  const cards = document.querySelectorAll<HTMLElement>('.blog-card');

  pills.forEach((pill) => {
    pill.addEventListener('click', () => {
      const cat = pill.dataset.cat ?? 'all';

      pills.forEach((p) => p.classList.remove('blog-filter__pill--active'));
      pill.classList.add('blog-filter__pill--active');

      cards.forEach((card) => {
        const show = cat === 'all' || card.dataset.cat === cat;
        card.style.display = show ? '' : 'none';
      });
    });
  });
</script>

<style>
  /* Hero */
  .blog-hero {
    position: relative;
    background: #06060F;
    padding: 140px 0 var(--space-16);
    overflow: hidden;
    text-align: center;
  }

  .blog-hero__bg {
    position: absolute;
    inset: 0;
    background: radial-gradient(ellipse 700px 400px at 50% 50%, rgba(4,119,191,0.12) 0%, transparent 70%);
    pointer-events: none;
  }

  .blog-hero__inner {
    position: relative;
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: var(--space-5);
  }

  .blog-hero__title {
    font-family: var(--font-headline);
    font-size: clamp(var(--text-3xl), 5vw, var(--text-6xl));
    font-weight: var(--weight-extrabold);
    line-height: var(--leading-tight);
    color: #ffffff;
  }

  .blog-hero__sub {
    font-size: var(--text-base);
    color: rgba(255,255,255,0.58);
    max-width: 520px;
    line-height: var(--leading-relaxed);
  }

  .blog-hero__count {
    display: flex;
    align-items: center;
    gap: var(--space-2);
    background: rgba(255,255,255,0.05);
    border: 1px solid rgba(255,255,255,0.08);
    border-radius: var(--radius-full);
    padding: var(--space-2) var(--space-5);
  }

  .blog-hero__count-val {
    font-family: var(--font-headline);
    font-weight: var(--weight-extrabold);
    font-size: var(--text-lg);
    color: var(--color-gold);
  }

  .blog-hero__count-lbl {
    font-family: var(--font-subhead);
    font-size: var(--text-sm);
    color: rgba(255,255,255,0.42);
    letter-spacing: var(--tracking-wide);
  }

  /* Filtro */
  .blog-filter {
    background: var(--color-bg-surface);
    border-bottom: 1px solid var(--color-border);
    padding-block: var(--space-4);
    position: sticky;
    top: 64px;
    z-index: 10;
  }

  .blog-filter__pills {
    display: flex;
    flex-wrap: wrap;
    gap: var(--space-2);
  }

  .blog-filter__pill {
    font-family: var(--font-subhead);
    font-size: var(--text-xs);
    font-weight: var(--weight-semibold);
    letter-spacing: var(--tracking-wide);
    text-transform: uppercase;
    color: var(--color-text-secondary);
    background: var(--color-bg);
    border: 1px solid var(--color-border);
    border-radius: var(--radius-full);
    padding: var(--space-2) var(--space-4);
    cursor: pointer;
    transition: color var(--transition-fast), background var(--transition-fast), border-color var(--transition-fast);
  }

  .blog-filter__pill:hover,
  .blog-filter__pill--active {
    color: #ffffff;
    background: var(--color-gold);
    border-color: var(--color-gold);
  }

  /* Grid */
  .blog-grid-section {
    background: var(--color-bg);
  }

  .blog-grid {
    display: grid;
    grid-template-columns: 1fr;
    gap: var(--space-5);
  }

  @media (min-width: 640px) { .blog-grid { grid-template-columns: repeat(2, 1fr); } }
  @media (min-width: 1024px) { .blog-grid { grid-template-columns: repeat(3, 1fr); } }

  /* Card */
  .blog-card {
    background: var(--color-bg-surface);
    border: 1px solid var(--color-border);
    border-radius: var(--radius-xl);
    overflow: hidden;
    display: flex;
    flex-direction: column;
    transition: transform var(--transition-slow), border-color var(--transition-base), box-shadow var(--transition-slow);
  }

  .blog-card:hover {
    transform: translateY(-3px);
    border-color: var(--color-border-hover);
    box-shadow: var(--shadow-card);
  }

  .blog-card__bar {
    height: 3px;
    width: 100%;
    flex-shrink: 0;
  }

  .blog-card__body {
    padding: var(--space-5) var(--space-6);
    display: flex;
    flex-direction: column;
    gap: var(--space-3);
    flex: 1;
  }

  .blog-card__top {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: var(--space-2);
  }

  .blog-card__cat {
    font-family: var(--font-subhead);
    font-size: 10px;
    font-weight: var(--weight-semibold);
    letter-spacing: var(--tracking-widest);
    text-transform: uppercase;
    border: 1px solid;
    border-radius: var(--radius-full);
    padding: 2px var(--space-3);
  }

  .blog-card__time {
    font-family: var(--font-subhead);
    font-size: 10px;
    color: var(--color-text-muted);
    letter-spacing: var(--tracking-wide);
    white-space: nowrap;
  }

  .blog-card__title {
    font-family: var(--font-headline);
    font-size: var(--text-base);
    font-weight: var(--weight-bold);
    line-height: var(--leading-snug);
    flex: 1;
  }

  .blog-card__link {
    color: var(--color-text-primary);
    text-decoration: none;
    transition: color var(--transition-fast);
  }

  .blog-card__link:hover { color: var(--color-gold); }

  .blog-card__excerpt {
    font-size: var(--text-sm);
    color: var(--color-text-secondary);
    line-height: var(--leading-relaxed);
    display: -webkit-box;
    -webkit-line-clamp: 3;
    -webkit-box-orient: vertical;
    overflow: hidden;
  }

  .blog-card__footer {
    display: flex;
    align-items: center;
    justify-content: space-between;
    padding-top: var(--space-3);
    border-top: 1px solid var(--color-border);
    margin-top: auto;
  }

  .blog-card__date {
    font-family: var(--font-subhead);
    font-size: var(--text-xs);
    color: var(--color-text-muted);
    letter-spacing: var(--tracking-wide);
  }

  .blog-card__cta {
    font-family: var(--font-subhead);
    font-size: var(--text-xs);
    font-weight: var(--weight-semibold);
    color: var(--color-gold);
    text-decoration: none;
    letter-spacing: var(--tracking-wide);
    transition: letter-spacing var(--transition-base);
  }

  .blog-card__cta:hover { letter-spacing: 0.12em; }
</style>
